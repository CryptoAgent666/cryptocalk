---
export interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
// ChangeNOW uses en-US instead of just 'en' for their locale
const widgetLang = lang === 'en' ? 'en-US' : lang;
---
<div class="changenow-widget-container" style="max-width: 400px; margin: 32px auto; background: var(--color-bg-card); border-radius: var(--radius-lg); overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.05);">
  <iframe 
    id="iframe-widget" 
    src={`https://changenow.io/embeds/exchange-widget/v2/widget.html?FAQ=false&amount=100&amountFiat=1500&backgroundColor=24252f&darkMode=true&from=usd&fromFiat=usd&horizontal=false&isFiat&lang=${widgetLang}&link_id=YOUR_AFFILIATE_ID&locales=true&logo=true&primaryColor=8b5cf6&to=btc&toFiat=eth&toTheMoon=true`} 
    style="border:none; width: 100%; height: 356px;" 
    sandbox="allow-scripts allow-same-origin allow-popups"
    loading="lazy"
    title="ChangeNOW Crypto Exchange Widget"
  ></iframe>
</div>
