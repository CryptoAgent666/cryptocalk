---
export interface Props {
  zoneId?: string;
  type?: 'banner' | 'square';
}
const { zoneId = 'YOUR_ZONE_ID', type = 'banner' } = Astro.props;
const height = type === 'banner' ? '90px' : '250px';
const width = type === 'banner' ? '100%' : '300px';
const maxWidth = type === 'banner' ? '728px' : '300px';
---
<div class={`ad-slot ad-${type}`} style={`min-height: ${height}; width: ${width}; max-width: ${maxWidth}; margin: 32px auto; background: var(--color-bg-card); border: 1px dashed var(--color-border); border-radius: var(--radius-sm); display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--color-text-muted); font-size: 0.75rem; text-align: center; overflow: hidden;`}>
  <span style="opacity: 0.5; margin-bottom: 4px;">Advertisement</span>
  <!-- Coinzilla / Bitmedia script placeholder -->
  <script is:inline type="text/javascript" data-zone={zoneId}>
    // Placeholder for ad network script
    // e.g. window.coinzilla_display = window.coinzilla_display || [];
  </script>
</div>
