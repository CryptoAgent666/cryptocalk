---
import { getLocalizedPath, type Lang } from '../i18n/utils';
import { getTranslations } from '../i18n/translations';

export interface Props {
    lang?: string;
}

const { lang = "en" } = Astro.props;
const t = getTranslations(lang as Lang);
const localPath = (route: string) => getLocalizedPath(route, lang as Lang);
const homeHref = getLocalizedPath('/', lang as Lang);

const coreLinks = [
    { name: t.profitCalculator, href: localPath('/profit-calculator') },
    { name: t.cryptoConverter, href: localPath('/converter') },
    { name: t.miningCalculator, href: localPath('/mining-calculator') },
    { name: t.dcaCalculator, href: localPath('/dca-calculator') },
    { name: t.taxCalculator, href: localPath('/tax-calculator') },
    { name: t.positionSizeCalculator, href: localPath('/position-size-calculator') },
];

const exploreLinks = [
    { name: t.stakingCalculator, href: localPath('/staking-calculator') },
    { name: t.gasCalculator, href: localPath('/gas-calculator') },
    { name: t.portfolioCalculator, href: localPath('/portfolio-calculator') },
    { name: t.whatIfCalculator, href: localPath('/what-if') },
    { name: t.breakEvenCalculator, href: localPath('/break-even-calculator') },
    { name: t.allCalculators.replace('← ', ''), href: homeHref },
];
---

<footer class="site-footer">
    <div class="footer-inner">
        <div class="footer-brand">
            <a href={homeHref} class="footer-logo">Crypto<b>Calk</b></a>
            <p>{t.footerTagline}</p>
            <a
                href="https://play.google.com/store/apps/details?id=com.cryptocalk.calculator"
                class="gplay-badge"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Get CryptoCalk on Google Play"
            >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" aria-hidden="true" class="gplay-icon">
                    <path d="M46.3 2.1c-3.5 2.1-8.3 7.3-8.3 20.5v466.8c0 13.2 4.8 18.4 8.3 20.5L271 256z" fill="#4285F4"/>
                    <path d="M271 256L46.3 509.9c3.1 1.7 7.2 2.3 11.9-.4l284.6-163.8z" fill="#EA4335"/>
                    <path d="M271 256l71.8-89.7L58.2 2.5c-4.7-2.7-8.8-2.1-11.9-.4z" fill="#34A853"/>
                    <path d="M342.8 345.7L474 270.3c19.5-11.2 19.5-29.4 0-40.6l-131.2-75.4L271 256z" fill="#FBBC04"/>
                </svg>
                <span class="gplay-text">
                    <span class="gplay-sub">GET IT ON</span>
                    <span class="gplay-main">Google Play</span>
                </span>
            </a>
        </div>
        <div class="footer-links">
            <div class="footer-col">
                <h4>{t.footerCoreCalculators}</h4>
                {coreLinks.map((link) => <a href={link.href}>{link.name}</a>)}
            </div>
            <div class="footer-col">
                <h4>{t.footerExplore}</h4>
                {
                    exploreLinks.map((link) => (
                        <a href={link.href}>{link.name}</a>
                    ))
                }
            </div>
            <div class="footer-col">
                <h4>{t.footerTrustLegal}</h4>
                <a href={localPath('/about')}>{t.footerAboutUs}</a>
                <a href={localPath('/contact')}>{t.footerContactUs}</a>
                <a href={localPath('/privacy')}>{t.privacyPolicy}</a>
                <a href={localPath('/terms')}>{t.footerTerms}</a>
                <a href={localPath('/editorial-policy')}>{t.editorialPolicy}</a>
                <a href={localPath('/methodology')}>{t.methodologyPolicy}</a>
                <a href={localPath('/updates')}>{t.footerUpdates}</a>
            </div>
        </div>
        <div class="footer-bottom">
            <p>{t.footerDisclaimer}</p>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        border-top: 1px solid var(--color-border);
        padding: 48px 0 32px;
    }

    .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
        display: grid;
        grid-template-columns: 200px 1fr;
        grid-template-rows: auto auto;
        gap: 32px 48px;
    }

    .footer-brand {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .footer-logo {
        font-size: 1.25rem;
        font-weight: 400;
        letter-spacing: -0.02em;
        color: var(--color-text);
        text-decoration: none;
    }

    .footer-logo b {
        font-weight: 800;
        background: linear-gradient(
            135deg,
            var(--color-primary),
            var(--color-accent-purple)
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .footer-brand p {
        font-size: 0.85rem;
        color: var(--color-text-muted);
    }

    .gplay-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 12px;
        padding: 8px 16px 8px 12px;
        background: #000;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 8px;
        text-decoration: none;
        width: fit-content;
        transition: border-color 0.15s ease;
    }

    .gplay-badge:hover {
        border-color: rgba(255, 255, 255, 0.5);
    }

    .gplay-icon {
        width: 24px;
        height: 24px;
        flex-shrink: 0;
    }

    .gplay-text {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
    }

    .gplay-sub {
        font-size: 0.6rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.8);
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .gplay-main {
        font-size: 1rem;
        font-weight: 600;
        color: #fff;
        letter-spacing: -0.01em;
    }

    .footer-links {
        display: flex;
        gap: 48px;
        flex-wrap: wrap;
    }

    .footer-col {
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-width: 140px;
    }

    .footer-col h4 {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-text-muted);
        margin-bottom: 4px;
    }

    .footer-col a {
        font-size: 0.875rem;
        color: var(--color-text-secondary);
        text-decoration: none;
        transition: color 0.15s ease;
    }

    .footer-col a:hover {
        color: var(--color-primary);
    }

    .footer-bottom {
        grid-column: 1 / -1;
        border-top: 1px solid var(--color-border);
        padding-top: 24px;
        text-align: center;
    }

    .footer-bottom p {
        font-size: 0.8rem;
        color: var(--color-text-muted);
    }

    @media (max-width: 768px) {
        .footer-inner {
            grid-template-columns: 1fr;
        }

        .footer-links {
            gap: 28px;
        }
    }
</style>
