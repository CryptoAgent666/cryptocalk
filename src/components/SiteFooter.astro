---
import { getLocalizedPath, type Lang } from '../i18n/utils';
import { getTranslations } from '../i18n/translations';

export interface Props {
    lang?: string;
}

const { lang = "en" } = Astro.props;
const t = getTranslations(lang as Lang);
const localPath = (route: string) => getLocalizedPath(route, lang as Lang);
const homeHref = getLocalizedPath('/', lang as Lang);

const coreLinks = [
    { name: t.profitCalculator, href: localPath('/profit-calculator') },
    { name: t.cryptoConverter, href: localPath('/converter') },
    { name: t.miningCalculator, href: localPath('/mining-calculator') },
    { name: t.dcaCalculator, href: localPath('/dca-calculator') },
    { name: t.taxCalculator, href: localPath('/tax-calculator') },
    { name: t.positionSizeCalculator, href: localPath('/position-size-calculator') },
];

const exploreLinks = [
    { name: t.stakingCalculator, href: localPath('/staking-calculator') },
    { name: t.gasCalculator, href: localPath('/gas-calculator') },
    { name: t.portfolioCalculator, href: localPath('/portfolio-calculator') },
    { name: t.whatIfCalculator, href: localPath('/what-if') },
    { name: t.breakEvenCalculator, href: localPath('/break-even-calculator') },
    { name: t.allCalculators.replace('← ', ''), href: homeHref },
];
---

<footer class="site-footer">
    <div class="footer-inner">
        <div class="footer-brand">
            <a href={homeHref} class="footer-logo">Crypto<b>Calk</b></a>
            <p>{t.footerTagline}</p>
            <a
                href="https://play.google.com/store/apps/details?id=com.cryptocalk.calculator"
                class="gplay-badge"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Get CryptoCalk on Google Play"
            >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" class="gplay-icon">
                    <path d="M3.18 23.76c.29.17.62.24.96.2l13.2-11.96-2.81-2.81L3.18 23.76z" fill="#EA4335"/>
                    <path d="M22.04 10.27 19.2 8.64l-3.17 2.87 3.17 3.17 2.87-1.65c.82-.47.82-1.29-.03-1.76z" fill="#FBBC04"/>
                    <path d="M3.18.24C2.85.48 2.63.9 2.63 1.47v21.06c0 .57.22.99.55 1.23l.1.07L14.54 12v-.24L3.18.24z" fill="#4285F4"/>
                    <path d="M14.54 12 3.18.24C3.5.07 3.9.1 4.26.31l13.16 7.5L14.54 12z" fill="#34A853"/>
                </svg>
                <span class="gplay-text">
                    <span class="gplay-sub">Get it on</span>
                    <span class="gplay-main">Google Play</span>
                </span>
            </a>
        </div>
        <div class="footer-links">
            <div class="footer-col">
                <h4>{t.footerCoreCalculators}</h4>
                {coreLinks.map((link) => <a href={link.href}>{link.name}</a>)}
            </div>
            <div class="footer-col">
                <h4>{t.footerExplore}</h4>
                {
                    exploreLinks.map((link) => (
                        <a href={link.href}>{link.name}</a>
                    ))
                }
            </div>
            <div class="footer-col">
                <h4>{t.footerTrustLegal}</h4>
                <a href={localPath('/about')}>{t.footerAboutUs}</a>
                <a href={localPath('/contact')}>{t.footerContactUs}</a>
                <a href={localPath('/privacy')}>{t.privacyPolicy}</a>
                <a href={localPath('/terms')}>{t.footerTerms}</a>
                <a href={localPath('/editorial-policy')}>{t.editorialPolicy}</a>
                <a href={localPath('/methodology')}>{t.methodologyPolicy}</a>
            </div>
        </div>
        <div class="footer-bottom">
            <p>{t.footerDisclaimer}</p>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        border-top: 1px solid var(--color-border);
        padding: 48px 0 32px;
    }

    .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
        display: grid;
        grid-template-columns: 200px 1fr;
        grid-template-rows: auto auto;
        gap: 32px 48px;
    }

    .footer-brand {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .footer-logo {
        font-size: 1.25rem;
        font-weight: 400;
        letter-spacing: -0.02em;
        color: var(--color-text);
        text-decoration: none;
    }

    .footer-logo b {
        font-weight: 800;
        background: linear-gradient(
            135deg,
            var(--color-primary),
            var(--color-accent-purple)
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .footer-brand p {
        font-size: 0.85rem;
        color: var(--color-text-muted);
    }

    .gplay-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 8px;
        padding: 8px 14px;
        background: var(--color-surface-2, #1e293b);
        border: 1px solid var(--color-border);
        border-radius: 10px;
        text-decoration: none;
        color: var(--color-text);
        transition: border-color 0.15s ease, background 0.15s ease;
        width: fit-content;
    }

    .gplay-badge:hover {
        border-color: var(--color-primary);
        background: var(--color-surface-3, #273449);
    }

    .gplay-icon {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
    }

    .gplay-text {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
    }

    .gplay-sub {
        font-size: 0.65rem;
        color: var(--color-text-muted);
        letter-spacing: 0.03em;
    }

    .gplay-main {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--color-text);
    }

    .footer-links {
        display: flex;
        gap: 48px;
        flex-wrap: wrap;
    }

    .footer-col {
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-width: 140px;
    }

    .footer-col h4 {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-text-muted);
        margin-bottom: 4px;
    }

    .footer-col a {
        font-size: 0.875rem;
        color: var(--color-text-secondary);
        text-decoration: none;
        transition: color 0.15s ease;
    }

    .footer-col a:hover {
        color: var(--color-primary);
    }

    .footer-bottom {
        grid-column: 1 / -1;
        border-top: 1px solid var(--color-border);
        padding-top: 24px;
        text-align: center;
    }

    .footer-bottom p {
        font-size: 0.8rem;
        color: var(--color-text-muted);
    }

    @media (max-width: 768px) {
        .footer-inner {
            grid-template-columns: 1fr;
        }

        .footer-links {
            gap: 28px;
        }
    }
</style>
