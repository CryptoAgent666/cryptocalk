---
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "./ThemeToggle.tsx";
import LanguageSwitcher from "./LanguageSwitcher.tsx";
import { getTranslations } from "../i18n/translations";
import { getLocalizedCalculatorMeta, getLocalizedPath, type Lang, type SpecCalculatorSlug } from "../i18n/utils";
import { CALCULATOR_META } from "../i18n/calculator-meta";
import { RELATED_CALCULATORS } from "../data/related-calculators";
import { CALCULATOR_CATEGORY, CATEGORY_NAMES } from "../data/calculator-category-map";
import { getActiveSections } from "../data/calculator-sections";
import { defaultFaqByLang } from "../i18n/faq-dictionary";
import { CALCULATOR_FAQ } from "../i18n/calculator-faq";
import { seoBodyText } from "../i18n/seo-body-text";
import { calculatorSeoContent } from "../i18n/calculator-seo-content";
import { calculatorSeoExt } from "../i18n/calculator-seo-ext";
import { Calculator, ChevronRight, ArrowLeft } from "lucide-react";
import ShareCalculator from "./ShareCalculator.astro";
import "../styles/calculator-page.css";
import SiteFooter from "./SiteFooter.astro";
import fs from "node:fs";
import path from "node:path";
import postcss from "postcss";

interface FaqItem {
  q: string;
  a: string;
}

export interface Props {
  lang: Lang;
  slug: string;
  title: string;
  description: string;
  faq?: FaqItem[];
  pathOverride?: string;
}

const { lang, slug, title, description, faq = [], pathOverride } = Astro.props;

const t = getTranslations(lang);
const prefix = lang === "en" ? "" : `/${lang}`;
const homePath = getLocalizedPath('/', lang);
const ensureTrailingSlash = (value: string) =>
  value === '/' || value.endsWith('/') ? value : `${value}/`;
const pagePath = ensureTrailingSlash(pathOverride ?? `${prefix}/${slug}`);
const localizedMeta = getLocalizedCalculatorMeta(
  slug,
  lang,
  title,
  description
);
const localizedTitle = localizedMeta.title;
const localizedDescription = localizedMeta.description;

const STYLE_BLOCK_RE = /<style(?:\s[^>]*)?>([\s\S]*?)<\/style>/g;
const scopedCssCache = new Map<string, string>();

function extractStyleBlocks(source: string): string {
  const blocks = Array.from(source.matchAll(STYLE_BLOCK_RE))
    .map((match) => match[1]?.trim() ?? "")
    .filter(Boolean);
  return blocks.join("\n\n");
}

function prefixCss(css: string, scope: string): string {
  const root = postcss.parse(css);

  root.walkRules((rule) => {
    if (!rule.selector) return;
    const parent = rule.parent;
    if (parent?.type === "atrule" && /keyframes$/i.test(parent.name)) return;

    const selectors = postcss.list
      .comma(rule.selector)
      .map((selector) => selector.trim())
      .filter(Boolean)
      .map((selector) => `${scope} ${selector}`);

    if (selectors.length > 0) {
      rule.selector = selectors.join(", ");
    }
  });

  return root.toString();
}

function getCalculatorScopedCss(currentSlug: string): string {
  const cached = scopedCssCache.get(currentSlug);
  if (cached !== undefined) return cached;

  try {
    const enPagePath = path.join(
      process.cwd(),
      "src/pages",
      `${currentSlug}.astro`
    );
    const source = fs.readFileSync(enPagePath, "utf-8");
    const rawStyle = extractStyleBlocks(source);
    if (!rawStyle) {
      scopedCssCache.set(currentSlug, "");
      return "";
    }
    const scope = `.calc-scope[data-slug="${currentSlug}"]`;
    const scoped = prefixCss(rawStyle, scope);
    scopedCssCache.set(currentSlug, scoped);
    return scoped;
  } catch {
    scopedCssCache.set(currentSlug, "");
    return "";
  }
}

const calculatorScopedCss = getCalculatorScopedCss(slug);

const relatedSlugs = RELATED_CALCULATORS[slug as SpecCalculatorSlug] ?? [];
const relatedLinks = relatedSlugs.map((rSlug) => {
  const meta = CALCULATOR_META[lang]?.[rSlug];
  const title = meta?.title ?? CALCULATOR_META['en']?.[rSlug]?.title ?? rSlug;
  const href = getLocalizedPath(`/${rSlug}`, lang);
  return { title, href };
});

const faqTemplate = faq.length
  ? faq
  : CALCULATOR_FAQ[slug]?.[lang] ?? defaultFaqByLang[lang] ?? defaultFaqByLang.en;

const faqItems = faqTemplate.map((item) => ({
  q: item.q.replace("{title}", localizedTitle),
  a: item.a.replace("{title}", localizedTitle),
}));

function buildHeadings(lt: string, lang: Lang) {
  const maps: Record<Lang, ReturnType<typeof buildHeadings>> = {
    en: {
      how: `How to use ${lt}`,
      inputs: "Input guide and assumptions",
      interpret: "How to interpret results correctly",
      scenarios: "Practical scenarios and planning workflow",
      checklist: "Risk and execution checklist",
      mistakes: "Common mistakes to avoid",
      benchmarks: "Performance benchmarks and expectation ranges",
      execution: "Execution templates you can reuse",
      hygiene: "Data hygiene and model maintenance",
      validation: "Final validation before capital deployment",
      faq: "Frequently asked questions",
      related: "Related calculators",
    },
    es: {
      how: `Cómo usar ${lt}`,
      inputs: "Guía de entradas y supuestos",
      interpret: "Cómo interpretar correctamente los resultados",
      scenarios: "Escenarios prácticos y flujo de planificación",
      checklist: "Checklist de riesgo y ejecución",
      mistakes: "Errores comunes a evitar",
      benchmarks: "Rangos de referencia y expectativas",
      execution: "Plantillas de ejecución reutilizables",
      hygiene: "Higiene de datos y mantenimiento del modelo",
      validation: "Validación final antes de desplegar capital",
      faq: "Preguntas frecuentes",
      related: "Calculadoras relacionadas",
    },
    pt: {
      how: `Como usar ${lt}`,
      inputs: "Guia de entradas e premissas",
      interpret: "Como interpretar os resultados corretamente",
      scenarios: "Cenários práticos e fluxo de planejamento",
      checklist: "Checklist de risco e execução",
      mistakes: "Erros comuns para evitar",
      benchmarks: "Referências de desempenho e faixas esperadas",
      execution: "Modelos de execução reutilizáveis",
      hygiene: "Higiene de dados e manutenção do modelo",
      validation: "Validação final antes de alocar capital",
      faq: "Perguntas frequentes",
      related: "Calculadoras relacionadas",
    },
    tr: {
      how: `${lt} nasıl kullanılır`,
      inputs: "Girdi rehberi ve varsayımlar",
      interpret: "Sonuçları doğru yorumlama",
      scenarios: "Pratik senaryolar ve planlama akışı",
      checklist: "Risk ve uygulama kontrol listesi",
      mistakes: "Kaçınılması gereken yaygın hatalar",
      benchmarks: "Performans kıyasları ve beklenti aralıkları",
      execution: "Tekrar kullanılabilir uygulama şablonları",
      hygiene: "Veri hijyeni ve model bakımı",
      validation: "Sermaye dağıtımı öncesi son doğrulama",
      faq: "Sık sorulan sorular",
      related: "İlgili hesaplayıcılar",
    },
    hi: {
      how: `${lt} का उपयोग कैसे करें`,
      inputs: "इनपुट गाइड और मान्यताएँ",
      interpret: "परिणामों को सही तरीके से समझना",
      scenarios: "व्यावहारिक परिदृश्य और योजना प्रक्रिया",
      checklist: "जोखिम और निष्पादन चेकलिस्ट",
      mistakes: "बचने योग्य सामान्य गलतियाँ",
      benchmarks: "प्रदर्शन बेंचमार्क और अपेक्षित रेंज",
      execution: "पुन: उपयोग योग्य निष्पादन टेम्पलेट",
      hygiene: "डेटा हाइजीन और मॉडल मेंटेनेंस",
      validation: "पूंजी लगाने से पहले अंतिम सत्यापन",
      faq: "अक्सर पूछे जाने वाले प्रश्न",
      related: "संबंधित कैलकुलेटर",
    },
    ru: {
      how: `Как использовать ${lt}`,
      inputs: "Гайд по входным параметрам и допущениям",
      interpret: "Как правильно интерпретировать результаты",
      scenarios: "Практические сценарии и рабочий процесс",
      checklist: "Чек-лист по рискам и исполнению",
      mistakes: "Типичные ошибки",
      benchmarks: "Бенчмарки доходности и диапазоны ожиданий",
      execution: "Повторяемые шаблоны исполнения",
      hygiene: "Гигиена данных и поддержка модели",
      validation: "Финальная проверка перед входом в позицию",
      faq: "Частые вопросы",
      related: "Связанные калькуляторы",
    },
  };
  return maps[lang] ?? maps.en;
}

const h = buildHeadings(localizedTitle, lang);

const activeSections = getActiveSections(slug);
const has = (s: string) => activeSections.includes(s as Parameters<typeof activeSections.includes>[0]);

// Per-calculator unique content overrides generic template.
// Merge order: genericTxt → calcOverride (how/inputs) → calcExtOverride (interpret…validation)
// Non-EN pages never receive English-only content — they use translated generic template.
const genericTxt = seoBodyText[lang] || seoBodyText.en;
const calcOverride = calculatorSeoContent[slug as string]?.[lang] ?? null;
const calcExtOverride = calculatorSeoExt[slug as string]?.[lang] ?? null;
const txt = { ...genericTxt, ...(calcOverride ?? {}), ...(calcExtOverride ?? {}) };

const siteUrl = "https://cryptocalk.com";
const pageUrl = `${siteUrl}${pagePath}`;
const homeUrl = `${siteUrl}${homePath}`;

// Category hub for breadcrumb & backlink
const categorySlug = CALCULATOR_CATEGORY[slug] ?? null;
const categoryName = categorySlug ? (CATEGORY_NAMES[categorySlug]?.[lang] ?? CATEGORY_NAMES[categorySlug]?.['en'] ?? '') : '';
const categoryHubPath = categorySlug ? getLocalizedPath(`/calculators/${categorySlug}`, lang) : null;
const categoryHubUrl = categoryHubPath ? `${siteUrl}${categoryHubPath}` : null;

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: localizedTitle,
  description: localizedDescription,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  inLanguage: lang,
  url: pageUrl,
  datePublished: "2025-11-01",
  dateModified: "2026-03-09",
  author: {
    "@type": "Person",
    name: "Konstantin Iakovlev",
    url: `${siteUrl}/about/`,
  },
};

const breadcrumbItems = [
  { "@type": "ListItem", position: 1, name: "CryptoCalk", item: homeUrl },
  ...(categoryHubUrl
    ? [{ "@type": "ListItem", position: 2, name: categoryName, item: categoryHubUrl },
       { "@type": "ListItem", position: 3, name: localizedTitle, item: pageUrl }]
    : [{ "@type": "ListItem", position: 2, name: localizedTitle, item: pageUrl }]),
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---

<Layout
  title={`${localizedTitle} — CryptoCalk`}
  description={localizedDescription}
  lang={lang}
>
  <header class="site-header">
    <div class="header-inner">
      <a href={homePath} class="logo">
        <Calculator size={24} />
        <span class="logo-text">Crypto<b>Calk</b></span>
      </a>
      <nav class="header-actions" aria-label="Main navigation">
        <a href={homePath} class="header-link">
          <ArrowLeft size={14} />
          {t.allCalculators}
        </a>
        <LanguageSwitcher
          client:idle
          currentLang={lang}
          currentPath={pagePath}
        />
        <ThemeToggle client:idle />
      </nav>
    </div>
  </header>

  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="section-container">
        <a href={homePath}>{t.home}</a>
        {categoryHubPath && (
          <>
            <ChevronRight size={12} />
            <a href={categoryHubPath}>{categoryName}</a>
          </>
        )}
        <ChevronRight size={12} />
        <a href={pagePath} aria-current="page">{localizedTitle}</a>
      </div>
    </nav>

    <section class="calculator-section">
      <div class="section-container">
        <div class="calc-header">
          <h1>{localizedTitle}</h1>
          <p>{localizedDescription}</p>
        </div>
        <div class="calc-scope" data-slug={slug}>
          <slot name="calculator" />
          <ShareCalculator lang={lang} />
        </div>
      </div>
    </section>

    <section class="seo-content">
      <div class="section-container prose">
        {has('how') && <>
          <h2>{h.how}</h2>
          {txt.how.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('inputs') && <>
          <h2>{h.inputs}</h2>
          {txt.inputs.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('interpret') && <>
          <h2>{h.interpret}</h2>
          {txt.interpret.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('scenarios') && <>
          <h2>{h.scenarios}</h2>
          {txt.scenarios.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('checklist') && <>
          <h2>{h.checklist}</h2>
          <ol class="checklist-list">
            {txt.checklist.map((p) => (
              <li>{p.replace(/{title}/g, localizedTitle)}</li>
            ))}
          </ol>
        </>}

        {has('mistakes') && <>
          <h2>{h.mistakes}</h2>
          <ul class="mistakes-list">
            {txt.mistakes.map((p) => (
              <li>{p.replace(/{title}/g, localizedTitle)}</li>
            ))}
          </ul>
        </>}

        {has('benchmarks') && <>
          <h2>{h.benchmarks}</h2>
          {txt.benchmarks.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('execution') && <>
          <h2>{h.execution}</h2>
          {txt.execution.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('hygiene') && <>
          <h2>{h.hygiene}</h2>
          {txt.hygiene.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('validation') && <>
          <h2>{h.validation}</h2>
          {txt.validation.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('faq') && <>
          <h2>{h.faq}</h2>
          {faqItems.map((item) => (
            <details>
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))}
        </>}

        {has('related') && (relatedLinks.length > 0 || categoryHubPath) && (
          <>
            <h2>{h.related}</h2>
            {relatedLinks.length > 0 && (
              <ul class="related-calculators-list">
                {relatedLinks.map((link) => (
                  <li><a href={link.href}>{link.title}</a></li>
                ))}
              </ul>
            )}
            {categoryHubPath && (
              <p class="hub-backlink">
                <a href={categoryHubPath}>← {t.allCategoryCalculators?.replace('{category}', categoryName) ?? `All ${categoryName} calculators`}</a>
              </p>
            )}
          </>
        )}
      </div>
    </section>
  </main>

  <SiteFooter lang={lang} />

  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)}
  ></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}
  ></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}
  ></script>
  {calculatorScopedCss && <style is:global set:html={calculatorScopedCss} />}
</Layout>

<style>
  /* Template-specific overrides (shared base in calculator-page.css) */
  .seo-content {
    padding: 8px 0 56px;
  }

  .prose {
    display: grid;
    gap: 14px;
    line-height: 1.7;
  }

  .prose h2 {
    margin-top: 12px;
    font-size: 1.35rem;
    line-height: 1.35;
  }

  .prose p {
    color: var(--color-text-secondary);
  }

  .prose details {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
  }

  .prose summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--color-text);
  }

  .prose details p {
    margin-top: 8px;
  }

  .related-calculators-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .related-calculators-list li a {
    display: inline-block;
    padding: 8px 16px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.15s ease;
  }

  .related-calculators-list li a:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: var(--color-bg-card-hover, var(--color-bg-card));
  }

  .checklist-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 10px;
    counter-reset: checklist-counter;
  }

  .checklist-list li {
    padding: 12px 16px 12px 48px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    position: relative;
    counter-increment: checklist-counter;
  }

  .checklist-list li::before {
    content: counter(checklist-counter);
    position: absolute;
    left: 14px;
    top: 12px;
    width: 22px;
    height: 22px;
    background: var(--color-primary);
    color: #fff;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mistakes-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 10px;
  }

  .mistakes-list li {
    padding: 12px 16px 12px 44px;
    background: rgba(239, 68, 68, 0.05);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    position: relative;
  }

  .mistakes-list li::before {
    content: '✕';
    position: absolute;
    left: 14px;
    top: 12px;
    width: 22px;
    height: 22px;
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .header-link {
      display: none;
    }
  }
</style>
