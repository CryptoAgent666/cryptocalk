---
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "./ThemeToggle.tsx";
import LanguageSwitcher from "./LanguageSwitcher.tsx";
import { getTranslations } from "../i18n/translations";
import { getLocalizedCalculatorMeta, type Lang } from "../i18n/utils";
import { defaultFaqByLang } from "../i18n/faq-dictionary";
import { seoBodyText } from "../i18n/seo-body-text";
import { Calculator, ChevronRight, ArrowLeft } from "lucide-react";
import AdSlot from "./AdSlot.astro";
import ShareCalculator from "./ShareCalculator.astro";
import fs from "node:fs";
import path from "node:path";
import postcss from "postcss";

interface FaqItem {
  q: string;
  a: string;
}

export interface Props {
  lang: Lang;
  slug: string;
  title: string;
  description: string;
  faq?: FaqItem[];
  pathOverride?: string;
}

const { lang, slug, title, description, faq = [], pathOverride } = Astro.props;

const t = getTranslations(lang);
const prefix = lang === "en" ? "" : `/${lang}`;
const pagePath = pathOverride ?? `${prefix}/${slug}`;
const localizedMeta = getLocalizedCalculatorMeta(
  slug,
  lang,
  title,
  description
);
const localizedTitle = localizedMeta.title;
const localizedDescription = localizedMeta.description;

const STYLE_BLOCK_RE = /<style(?:\s[^>]*)?>([\s\S]*?)<\/style>/g;
const scopedCssCache = new Map<string, string>();

function extractStyleBlocks(source: string): string {
  const blocks = Array.from(source.matchAll(STYLE_BLOCK_RE))
    .map((match) => match[1]?.trim() ?? "")
    .filter(Boolean);
  return blocks.join("\n\n");
}

function prefixCss(css: string, scope: string): string {
  const root = postcss.parse(css);

  root.walkRules((rule) => {
    if (!rule.selector) return;
    const parent = rule.parent;
    if (parent?.type === "atrule" && /keyframes$/i.test(parent.name)) return;

    const selectors = postcss.list
      .comma(rule.selector)
      .map((selector) => selector.trim())
      .filter(Boolean)
      .map((selector) => `${scope} ${selector}`);

    if (selectors.length > 0) {
      rule.selector = selectors.join(", ");
    }
  });

  return root.toString();
}

function getCalculatorScopedCss(currentSlug: string): string {
  const cached = scopedCssCache.get(currentSlug);
  if (cached !== undefined) return cached;

  try {
    const enPagePath = path.join(
      process.cwd(),
      "src/pages",
      `${currentSlug}.astro`
    );
    const source = fs.readFileSync(enPagePath, "utf-8");
    const rawStyle = extractStyleBlocks(source);
    if (!rawStyle) {
      scopedCssCache.set(currentSlug, "");
      return "";
    }
    const scope = `.calc-scope[data-slug="${currentSlug}"]`;
    const scoped = prefixCss(rawStyle, scope);
    scopedCssCache.set(currentSlug, scoped);
    return scoped;
  } catch {
    scopedCssCache.set(currentSlug, "");
    return "";
  }
}

const calculatorScopedCss = getCalculatorScopedCss(slug);

const faqTemplate = faq.length
  ? faq
  : defaultFaqByLang[lang] || defaultFaqByLang.en;

const faqItems = faqTemplate.map((item) => ({
  q: item.q.replace("{title}", localizedTitle),
  a: item.a.replace("{title}", localizedTitle),
}));

const headingMap: Record<
  Lang,
  {
    how: string;
    inputs: string;
    interpret: string;
    scenarios: string;
    checklist: string;
    mistakes: string;
    benchmarks: string;
    execution: string;
    hygiene: string;
    validation: string;
    faq: string;
    related: string;
  }
> = {
  en: {
    how: `How to use ${title}`,
    inputs: "Input guide and assumptions",
    interpret: "How to interpret results correctly",
    scenarios: "Practical scenarios and planning workflow",
    checklist: "Risk and execution checklist",
    mistakes: "Common mistakes to avoid",
    benchmarks: "Performance benchmarks and expectation ranges",
    execution: "Execution templates you can reuse",
    hygiene: "Data hygiene and model maintenance",
    validation: "Final validation before capital deployment",
    faq: "Frequently asked questions",
    related: "Related calculators",
  },
  es: {
    how: `Cómo usar ${title}`,
    inputs: "Guía de entradas y supuestos",
    interpret: "Cómo interpretar correctamente los resultados",
    scenarios: "Escenarios prácticos y flujo de planificación",
    checklist: "Checklist de riesgo y ejecución",
    mistakes: "Errores comunes a evitar",
    benchmarks: "Rangos de referencia y expectativas",
    execution: "Plantillas de ejecución reutilizables",
    hygiene: "Higiene de datos y mantenimiento del modelo",
    validation: "Validación final antes de desplegar capital",
    faq: "Preguntas frecuentes",
    related: "Calculadoras relacionadas",
  },
  pt: {
    how: `Como usar ${title}`,
    inputs: "Guia de entradas e premissas",
    interpret: "Como interpretar os resultados corretamente",
    scenarios: "Cenários práticos e fluxo de planejamento",
    checklist: "Checklist de risco e execução",
    mistakes: "Erros comuns para evitar",
    benchmarks: "Referências de desempenho e faixas esperadas",
    execution: "Modelos de execução reutilizáveis",
    hygiene: "Higiene de dados e manutenção do modelo",
    validation: "Validação final antes de alocar capital",
    faq: "Perguntas frequentes",
    related: "Calculadoras relacionadas",
  },
  tr: {
    how: `${title} nasıl kullanılır`,
    inputs: "Girdi rehberi ve varsayımlar",
    interpret: "Sonuçları doğru yorumlama",
    scenarios: "Pratik senaryolar ve planlama akışı",
    checklist: "Risk ve uygulama kontrol listesi",
    mistakes: "Kaçınılması gereken yaygın hatalar",
    benchmarks: "Performans kıyasları ve beklenti aralıkları",
    execution: "Tekrar kullanılabilir uygulama şablonları",
    hygiene: "Veri hijyeni ve model bakımı",
    validation: "Sermaye dağıtımı öncesi son doğrulama",
    faq: "Sık sorulan sorular",
    related: "İlgili hesaplayıcılar",
  },
  hi: {
    how: `${title} का उपयोग कैसे करें`,
    inputs: "इनपुट गाइड और मान्यताएँ",
    interpret: "परिणामों को सही तरीके से समझना",
    scenarios: "व्यावहारिक परिदृश्य और योजना प्रक्रिया",
    checklist: "जोखिम और निष्पादन चेकलिस्ट",
    mistakes: "बचने योग्य सामान्य गलतियाँ",
    benchmarks: "प्रदर्शन बेंचमार्क और अपेक्षित रेंज",
    execution: "पुन: उपयोग योग्य निष्पादन टेम्पलेट",
    hygiene: "डेटा हाइजीन और मॉडल मेंटेनेंस",
    validation: "पूंजी लगाने से पहले अंतिम सत्यापन",
    faq: "अक्सर पूछे जाने वाले प्रश्न",
    related: "संबंधित कैलकुलेटर",
  },
  ru: {
    how: `Как использовать ${title}`,
    inputs: "Гайд по входным параметрам и допущениям",
    interpret: "Как правильно интерпретировать результаты",
    scenarios: "Практические сценарии и рабочий процесс",
    checklist: "Чек-лист по рискам и исполнению",
    mistakes: "Типичные ошибки",
    benchmarks: "Бенчмарки доходности и диапазоны ожиданий",
    execution: "Повторяемые шаблоны исполнения",
    hygiene: "Гигиена данных и поддержка модели",
    validation: "Финальная проверка перед входом в позицию",
    faq: "Частые вопросы",
    related: "Связанные калькуляторы",
  },
};

const h = headingMap[lang] || headingMap.en;
const txt = seoBodyText[lang] || seoBodyText.en;

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: localizedTitle,
  description: localizedDescription,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  inLanguage: lang,
  url: `https://cryptocalk.com${pagePath}`,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---

<Layout
  title={`${localizedTitle} — CryptoCalk`}
  description={localizedDescription}
  lang={lang}
>
  <header class="site-header">
    <div class="header-inner">
      <a href={prefix || "/"} class="logo">
        <Calculator size={24} />
        <span class="logo-text">Crypto<b>Calk</b></span>
      </a>
      <div class="header-actions">
        <a href={prefix || "/"} class="header-link">
          <ArrowLeft size={14} />
          {t.allCalculators}
        </a>
        <LanguageSwitcher
          client:idle
          currentLang={lang}
          currentPath={pagePath}
        />
        <ThemeToggle client:idle />
      </div>
    </div>
  </header>

  <main>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="section-container">
        <a href={prefix || "/"}>{t.home}</a>
        <ChevronRight size={12} />
        <a href={pagePath} aria-current="page">{localizedTitle}</a>
      </div>
    </nav>

    <section class="calculator-section">
      <div class="section-container">
        <!-- Top Ad Slot -->
        <AdSlot type="banner" zoneId="header_banner" />

        <div class="calc-header">
          <h1>{localizedTitle}</h1>
          <p>{localizedDescription}</p>
        </div>
        <div class="calc-scope" data-slug={slug}>
          <ShareCalculator lang={lang} />
          <slot name="calculator" />
        </div>

        <!-- Bottom Ad Slot -->
        <AdSlot type="banner" zoneId="footer_banner" />
      </div>
    </section>

    <section class="seo-content">
      <div class="section-container prose">
        <h2>{h.how}</h2>
        {txt.how.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}

        <h2>{h.inputs}</h2>
        {txt.inputs.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}

        <h2>{h.interpret}</h2>
        {
          txt.interpret.map((p) => (
            <p>{p.replace(/{title}/g, localizedTitle)}</p>
          ))
        }

        <h2>{h.scenarios}</h2>
        {
          txt.scenarios.map((p) => (
            <p>{p.replace(/{title}/g, localizedTitle)}</p>
          ))
        }

        <h2>{h.checklist}</h2>
        {
          txt.checklist.map((p) => (
            <p>{p.replace(/{title}/g, localizedTitle)}</p>
          ))
        }

        <h2>{h.mistakes}</h2>
        {
          txt.mistakes.map((p) => (
            <p>{p.replace(/{title}/g, localizedTitle)}</p>
          ))
        }

        <h2>{h.benchmarks}</h2>
        {
          txt.benchmarks.map((p) => (
            <p>{p.replace(/{title}/g, localizedTitle)}</p>
          ))
        }

        <h2>{h.execution}</h2>
        {
          txt.execution.map((p) => (
            <p>{p.replace(/{title}/g, localizedTitle)}</p>
          ))
        }

        <h2>{h.hygiene}</h2>
        {txt.hygiene.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}

        <h2>{h.validation}</h2>
        {
          txt.validation.map((p) => (
            <p>{p.replace(/{title}/g, localizedTitle)}</p>
          ))
        }

        <h2>{h.faq}</h2>
        {
          faqItems.map((item) => (
            <details>
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))
        }

        <h2>{h.related}</h2>
        <p>
          To improve decision quality, pair {localizedTitle} with at least one complementary
          tool: use Profit/ROI for return validation, Position Size and Risk/Reward
          for risk control, Break-Even for fee-adjusted thresholds, and Tax tools
          for post-trade net analysis. Using tools in combination gives better outcomes
          than relying on a single isolated metric.
        </p>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div
        class="footer-links-row"
        style="display: flex; gap: 16px; justify-content: center; margin-bottom: 16px; flex-wrap: wrap;"
      >
        <a
          href="/about"
          style="color: var(--color-text-secondary); text-decoration: none; font-size: 0.85rem;"
          >About Us</a
        >
        <a
          href="/contact"
          style="color: var(--color-text-secondary); text-decoration: none; font-size: 0.85rem;"
          >Contact Us</a
        >
        <a
          href="/privacy"
          style="color: var(--color-text-secondary); text-decoration: none; font-size: 0.85rem;"
          >Privacy Policy</a
        >
        <a
          href="/terms"
          style="color: var(--color-text-secondary); text-decoration: none; font-size: 0.85rem;"
          >Terms of Service</a
        >
      </div>
      <div class="footer-bottom" style="text-align: center;">
        <p>{t.footerText}</p>
      </div>
    </div>
  </footer>

  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)}
  ></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}
  ></script>
  {calculatorScopedCss && <style is:global set:html={calculatorScopedCss} />}
</Layout>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg-header);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text);
    font-size: 1.25rem;
    font-weight: 600;
    text-decoration: none;
    min-width: 0;
  }

  .logo:hover {
    color: var(--color-text);
  }

  .logo-text {
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .logo-text b {
    font-weight: 800;
    background: linear-gradient(
      135deg,
      var(--color-primary),
      var(--color-accent-purple)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .header-link {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .header-link:hover {
    color: var(--color-text);
  }

  .breadcrumb {
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .breadcrumb .section-container {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a[aria-current] {
    color: var(--color-text);
    font-weight: 600;
  }

  .section-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .calculator-section {
    padding: 40px 0 56px;
  }

  .calc-header {
    text-align: center;
    margin-bottom: 28px;
  }

  .calc-header h1 {
    font-size: clamp(1.6rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 8px;
  }

  .calc-header p {
    color: var(--color-text-secondary);
    font-size: 1rem;
    max-width: 820px;
    margin: 0 auto;
  }

  .seo-content {
    padding: 8px 0 56px;
  }

  .prose {
    display: grid;
    gap: 14px;
    line-height: 1.7;
  }

  .prose h2 {
    margin-top: 12px;
    font-size: 1.35rem;
    line-height: 1.35;
  }

  .prose p {
    color: var(--color-text-secondary);
  }

  .prose details {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
  }

  .prose summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--color-text);
  }

  .prose details p {
    margin-top: 8px;
  }

  .site-footer {
    padding: 24px 0;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (max-width: 900px) {
    .header-link {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .header-inner {
      height: auto;
      min-height: 64px;
      padding-top: 10px;
      padding-bottom: 10px;
    }

    .logo-text {
      font-size: 1.08rem;
    }

    .section-container {
      padding: 0 16px;
    }
  }
</style>
