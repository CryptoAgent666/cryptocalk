    'concentrated-liquidity-calculator': { interpret: 'Reading your LP position', scenarios: 'Range strategy scenarios', benchmarks: 'Concentrated LP return benchmarks', mistakes: 'Common V3 LP mistakes' },
    'looping-yield-calculator': { interpret: 'Reading your loop position', scenarios: 'Loop strategy scenarios', benchmarks: 'Loop profitability benchmarks', mistakes: 'Looping mistakes that liquidate' },
    'mining-roi-calculator': { interpret: 'Reading your mining ROI', scenarios: 'Mining payback scenarios', benchmarks: 'ASIC ROI benchmarks', validation: 'Before buying mining hardware' },
    'sharpe-calculator': { interpret: 'Reading your Sharpe ratio', benchmarks: 'Sharpe benchmarks by asset class', validation: 'Verifying your Sharpe calculation' },
    'sortino-calculator': { interpret: 'Reading your Sortino ratio', benchmarks: 'Sortino vs Sharpe comparison', mistakes: 'Common Sortino mistakes' },
    'kelly-calculator': { interpret: 'Reading the Kelly fraction', scenarios: 'Kelly sizing scenarios', mistakes: 'Why full Kelly is too aggressive' },
    'var-calculator': { interpret: 'Reading your Value-at-Risk', scenarios: 'VaR scenarios for crypto portfolios', validation: 'Cross-checking VaR assumptions' },
    'halving-calculator': { interpret: 'Reading halving impact estimates', scenarios: 'Past halving comparison', benchmarks: 'Historical halving outcomes' },
    'options-calculator': { interpret: 'Reading option Greeks', scenarios: 'Common option strategies', mistakes: 'Options pricing pitfalls' },
    'impermanent-loss-calculator': { interpret: 'Reading IL impact on your LP', scenarios: 'Price-move IL scenarios', benchmarks: 'IL benchmarks across pools' },
  },
};

const overrides = HEADING_OVERRIDES[lang]?.[slug as string] ?? {};
const h = { ...baseH, ...overrides };

// Generate URL-safe id anchors for deep linking (AI citation + accessibility)
function slugify(text: string): string {
  return text.toLowerCase().replace(/[^a-z0-9\u0400-\u04ff\u0900-\u097f]+/g, '-').replace(/^-|-$/g, '').slice(0, 80);
}
const hId = Object.fromEntries(
  Object.entries(h).map(([key, val]) => [key, slugify(val)])
) as Record<keyof typeof h, string>;

const activeSections = getActiveSections(slug);
const has = (s: string) => activeSections.includes(s as Parameters<typeof activeSections.includes>[0]);

// Per-calculator unique content overrides generic template.
// Merge order: genericTxt → calcOverride (how/inputs) → calcExtOverride (interpret…validation)
// Non-EN pages never receive English-only content — they use translated generic template.
const genericTxt = seoBodyText[lang] || seoBodyText.en;
const calcOverride = calculatorSeoContent[slug as string]?.[lang] ?? null;
const calcExtOverride = calculatorSeoExt[slug as string]?.[lang] ?? null;
const rawTxt = { ...genericTxt, ...(calcOverride ?? {}), ...(calcExtOverride ?? {}) };

// Localize internal links for non-EN pages: /profit-calculator/ → /es/calculadora-beneficio-cripto/
function localizeLinks(paragraphs: string[], pageLang: Lang): string[] {
  if (pageLang === 'en') return paragraphs;
  return paragraphs.map(p =>
    p.replace(/href="(\/[a-z0-9-]+\/?)"/g, (_match, enPath) => {
      const localized = getLocalizedPath(enPath.replace(/\/$/, ''), pageLang);
      return `href="${localized}"`;
    })
  );
}

const txt = Object.fromEntries(
  Object.entries(rawTxt).map(([key, val]) => [key, Array.isArray(val) ? localizeLinks(val, lang) : val])
) as typeof rawTxt;

// Quick Answer
const calcContent = calculatorSeoContent[slug as string];
const quickAnswer = calcContent?.[lang]?.quickAnswer || calcContent?.['en']?.quickAnswer || '';

const siteUrl = "https://cryptocalk.com";
const pageUrl = `${siteUrl}${pagePath}`;
const homeUrl = `${siteUrl}${homePath}`;

// Category hub for breadcrumb & backlink
const categorySlug = CALCULATOR_CATEGORY[slug] ?? null;
const categoryName = categorySlug ? (CATEGORY_NAMES[categorySlug]?.[lang] ?? CATEGORY_NAMES[categorySlug]?.['en'] ?? '') : '';
const categoryHubPath = categorySlug ? getLocalizedPath(`/calculators/${categorySlug}`, lang) : null;
const categoryHubUrl = categoryHubPath ? `${siteUrl}${categoryHubPath}` : null;

const buildDate = new Date().toISOString().split('T')[0];
const buildDateTime = new Date().toISOString();

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "@id": `${pageUrl}#app`,
  name: localizedTitle,
  description: localizedDescription,
  applicationCategory: "FinanceApplication",
  operatingSystem: "All",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  inLanguage: lang,
  url: pageUrl,
  datePublished: "2025-11-01T00:00:00+00:00",
  dateModified: buildDateTime,
  author: {
    "@type": "Person",
    "@id": `${siteUrl}/about/#founder`,
    name: "Konstantin Iakovlev",
    url: `${siteUrl}/about/`,
  },
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${pageUrl}#webpage`,
  url: pageUrl,
  name: localizedTitle,
  description: localizedDescription,
  inLanguage: lang,
  isPartOf: { "@type": "WebSite", "@id": `${siteUrl}/#website` },
  datePublished: "2025-11-01T00:00:00+00:00",
  dateModified: buildDateTime,
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".calc-header h1", ".calc-header p"],
  },
  author: {
    "@type": "Person",
    "@id": `${siteUrl}/about/#founder`,
    name: "Konstantin Iakovlev",
    url: `${siteUrl}/about/`,
  },
};

const breadcrumbItems = [
  { "@type": "ListItem", position: 1, name: "CryptoCalk", item: homeUrl },
  ...(categoryHubUrl
    ? [{ "@type": "ListItem", position: 2, name: categoryName, item: categoryHubUrl },
       { "@type": "ListItem", position: 3, name: localizedTitle, item: pageUrl }]
    : [{ "@type": "ListItem", position: 2, name: localizedTitle, item: pageUrl }]),
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};

// HowTo schema — boosts rich-result eligibility on "how to use X" queries
// Uses the existing How / Inputs / Interpret / Validation section copy
const howToStepFromText = (name: string, text: string | undefined) => {
  if (!text) return null;
  return {
    "@type": "HowToStep",
    name,
    text: text.replace(/<[^>]+>/g, "").slice(0, 400),
  };
};
const howToSteps = [
  howToStepFromText(
    h.inputs,
    txt.inputs?.[0]?.replace(/\{title\}/g, localizedTitle),
  ),
  howToStepFromText(
    h.how,
    txt.how?.[0]?.replace(/\{title\}/g, localizedTitle),
  ),
  howToStepFromText(
    h.interpret,
    txt.interpret?.[0]?.replace(/\{title\}/g, localizedTitle),
  ),
  howToStepFromText(
    h.validation,
    txt.validation?.[0]?.replace(/\{title\}/g, localizedTitle),
  ),
].filter(Boolean);

const howToSchema = howToSteps.length >= 3 ? {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: h.how,
  description: localizedDescription,
  totalTime: "PT2M",
  step: howToSteps,
  inLanguage: lang,
} : null;
---

<Layout
  title={`${localizedTitle} — CryptoCalk`}
  description={localizedDescription}
  lang={lang}
>
  <header class="site-header">
    <div class="header-inner">
      <a href={homePath} class="logo">
        <Calculator size={24} />
        <span class="logo-text">Crypto<b>Calk</b></span>
      </a>
      <nav class="header-actions" aria-label="Main navigation">
        <a href={homePath} class="header-link">
          <ArrowLeft size={14} />
          {t.allCalculators}
        </a>
        <LanguageSwitcher
          client:idle
          currentLang={lang}
          currentPath={pagePath}
        />
        <ThemeToggle client:idle />
      </nav>
    </div>
  </header>

  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="section-container">
        <a href={homePath}>{t.home}</a>
        {categoryHubPath && (
          <>
            <ChevronRight size={12} />
            <a href={categoryHubPath}>{categoryName}</a>
          </>
        )}
        <ChevronRight size={12} />
        <a href={pagePath} aria-current="page">{localizedTitle}</a>
      </div>
    </nav>

    {lang !== 'en' && (
      <script is:inline define:vars={{ _clientLangJson, lang }}>
        // Register UI translation strings before React hydration.
        // This runs synchronously (non-module), so the registry is populated
        // before any module <script type="module"> hydration code executes.
        (function() {
          var d = JSON.parse(_clientLangJson);
          var r = window.__uiStringRegistry;
          if (!r) { r = {}; window.__uiStringRegistry = r; }
          r[lang] = d;
        })();
      </script>
    )}
    <section class="calculator-section">
      <div class="section-container">
        <div class="calc-header">
          <h1>{localizedTitle}</h1>
          <p>{localizedDescription}</p>
          <div class="calc-byline">
            <a href={`${prefix}/about/`} class="byline-link">
              <span class="byline-by">{lang === 'es' ? 'Por' : lang === 'pt' ? 'Por' : lang === 'tr' ? 'Yazan' : lang === 'hi' ? 'लेखक' : lang === 'ru' ? 'Автор' : 'By'}</span>
              <span class="byline-name">Konstantin Iakovlev</span>
            </a>
            <span class="byline-sep">·</span>
            <span class="byline-date">{lang === 'es' ? 'Actualizado' : lang === 'pt' ? 'Atualizado' : lang === 'tr' ? 'Güncellendi' : lang === 'hi' ? 'अपडेट' : lang === 'ru' ? 'Обновлено' : 'Updated'} {buildDate}</span>
          </div>
        </div>
        <div class="calc-scope" data-slug={slug}>
          <slot name="calculator" />
          <ShareCalculator lang={lang} />
        </div>
      </div>
    </section>

    <section class="seo-content">
      <div class="section-container prose">
        {quickAnswer && (
          <div class="quick-answer">
            <strong>{lang === 'es' ? 'Respuesta rápida:' : lang === 'pt' ? 'Resposta rápida:' : lang === 'tr' ? 'Hızlı cevap:' : lang === 'hi' ? 'त्वरित उत्तर:' : lang === 'ru' ? 'Быстрый ответ:' : 'Quick answer:'}</strong>{' '}
            <Fragment set:html={quickAnswer} />
          </div>
        )}
        {has('how') && <>
          <h2 id={hId.how}>{h.how}</h2>
          {txt.how.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('inputs') && <>
          <h2 id={hId.inputs}>{h.inputs}</h2>
          {txt.inputs.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('interpret') && <>
          <h2 id={hId.interpret}>{h.interpret}</h2>
          {txt.interpret.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('scenarios') && <>
          <h2 id={hId.scenarios}>{h.scenarios}</h2>
          {txt.scenarios.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('checklist') && <>
          <h2 id={hId.checklist}>{h.checklist}</h2>
          <ol class="checklist-list">
            {txt.checklist.map((p) => (
              <li>{p.replace(/{title}/g, localizedTitle)}</li>
            ))}
          </ol>
        </>}

        {has('mistakes') && <>
          <h2 id={hId.mistakes}>{h.mistakes}</h2>
          <ul class="mistakes-list">
            {txt.mistakes.map((p) => (
              <li>{p.replace(/{title}/g, localizedTitle)}</li>
            ))}
          </ul>
        </>}

        {has('benchmarks') && <>
          <h2 id={hId.benchmarks}>{h.benchmarks}</h2>
          {txt.benchmarks.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('execution') && <>
          <h2 id={hId.execution}>{h.execution}</h2>
          {txt.execution.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('hygiene') && <>
          <h2 id={hId.hygiene}>{h.hygiene}</h2>
          {txt.hygiene.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('validation') && <>
          <h2 id={hId.validation}>{h.validation}</h2>
          {txt.validation.map((p) => <p>{p.replace(/{title}/g, localizedTitle)}</p>)}
        </>}

        {has('faq') && <>
          <h2 id={hId.faq}>{h.faq}</h2>
          {faqItems.map((item) => (
            <details>
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))}
        </>}

        {has('related') && (relatedLinks.length > 0 || categoryHubPath) && (
          <>
            <h2 id={hId.related}>{h.related}</h2>
            {relatedLinks.length > 0 && (
              <ul class="related-calculators-list">
                {relatedLinks.map((link) => (
                  <li><a href={link.href}>{link.title}</a></li>
                ))}
              </ul>
            )}
            {categoryHubPath && (
              <p class="hub-backlink">
                <a href={categoryHubPath}>← {t.allCategoryCalculators?.replace('{category}', categoryName) ?? `All ${categoryName} calculators`}</a>
              </p>
            )}
          </>
        )}

        {popularLinks.length > 0 && (
          <>
            <h2 class="popular-calcs-title">{popularLabel}</h2>
            <ul class="popular-calcs-list">
              {popularLinks.map((link) => (
                <li><a href={link.href}>{link.title}</a></li>
              ))}
            </ul>
          </>
        )}
      </div>
    </section>
  </main>

  <SiteFooter lang={lang} />

  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)}
  />
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)}
  ></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}
  ></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}
  ></script>
  {howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}
  {calculatorScopedCss && <style is:global set:html={calculatorScopedCss} />}
</Layout>

