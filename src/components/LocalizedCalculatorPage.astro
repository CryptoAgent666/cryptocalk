  en: 'Popular calculators',
  es: 'Calculadoras populares',
  pt: 'Calculadoras populares',
  tr: 'Popüler hesaplayıcılar',
  hi: 'लोकप्रिय कैलकुलेटर',
  ru: 'Популярные калькуляторы',
};
const popularLabel = POPULAR_LABEL[lang] ?? POPULAR_LABEL.en;

const faqTemplate = faq.length
  ? faq
