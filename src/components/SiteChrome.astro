---
import { Calculator, ArrowLeft } from 'lucide-react';
import LanguageSwitcher from './LanguageSwitcher.tsx';
import ThemeToggle from './ThemeToggle.tsx';
import { getTranslations } from '../i18n/translations';
import { getLocalizedPath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props as Props;
const t = getTranslations(lang);

const homeHref = getLocalizedPath('/', lang);
const allToolsHref = `${homeHref}#categories`;
const privacyHref = getLocalizedPath('/privacy', lang);
const editorialHref = getLocalizedPath('/editorial-policy', lang);
const methodologyHref = getLocalizedPath('/methodology', lang);
---

<header class="site-chrome-header">
  <div class="site-chrome-inner">
    <a href={homeHref} class="site-chrome-logo">
      <Calculator size={24} />
      <span class="logo-text">Crypto<b>Calk</b></span>
    </a>
    <div class="site-chrome-actions">
      <a href={allToolsHref} class="site-chrome-link">
        <ArrowLeft size={14} />
        {t.allToolsTitle}
      </a>
      <LanguageSwitcher client:idle currentLang={lang} currentPath={currentPath} />
      <ThemeToggle client:idle />
    </div>
  </div>
</header>

<slot />

<footer class="site-chrome-footer">
  <div class="site-chrome-inner">
    <div class="site-chrome-brand">
      <span class="logo-text">Crypto<b>Calk</b></span>
      <p>{t.heroSubtitle}</p>
    </div>
    <div class="site-chrome-links">
      <a href={privacyHref}>{t.privacyPolicy}</a>
      <a href={editorialHref}>{t.editorialPolicy}</a>
      <a href={methodologyHref}>{t.methodologyPolicy}</a>
    </div>
    <p class="site-chrome-copy">{t.footerText}</p>
  </div>
</footer>

<style>
  .site-chrome-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg-header);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-header);
  }

  .site-chrome-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .site-chrome-header .site-chrome-inner {
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .site-chrome-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text);
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .logo-text {
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .logo-text b {
    font-weight: 800;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .site-chrome-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .site-chrome-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: var(--color-text-secondary);
    font-size: 0.84rem;
    font-weight: 600;
  }

  .site-chrome-link:hover {
    color: var(--color-primary);
  }

  .site-chrome-footer {
    border-top: 1px solid var(--color-border);
    padding: 28px 0;
    background-color: var(--color-bg-card);
  }

  .site-chrome-brand p {
    margin: 8px 0 0;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    max-width: 76ch;
  }

  .site-chrome-links {
    margin-top: 16px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .site-chrome-links a {
    text-decoration: none;
    color: var(--color-text-secondary);
    font-size: 0.84rem;
    font-weight: 500;
  }

  .site-chrome-links a:hover {
    color: var(--color-primary);
  }

  .site-chrome-copy {
    margin: 18px 0 0;
    color: var(--color-text-muted);
    font-size: 0.78rem;
  }

  @media (max-width: 768px) {
    .site-chrome-inner {
      padding: 0 12px;
    }

    .site-chrome-header .site-chrome-inner {
      min-height: 56px;
      gap: 8px;
    }

    .site-chrome-link {
      font-size: 0.78rem;
    }

    .site-chrome-footer {
      padding: 24px 0;
    }

    .site-chrome-brand p {
      font-size: 0.84rem;
    }
  }
</style>
