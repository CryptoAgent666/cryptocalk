---
import type { Lang } from '../i18n/utils';

export interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;

const copy: Record<string, { text: string; accept: string; decline: string; learnMore: string }> = {
  en: {
    text: 'We use cookies for analytics and personalised advertising. You can accept all or use essential cookies only.',
    accept: 'Accept all',
    decline: 'Essential only',
    learnMore: 'Privacy Policy',
  },
  es: {
    text: 'Usamos cookies para estadísticas y publicidad personalizada. Puedes aceptar todo o usar solo las cookies esenciales.',
    accept: 'Aceptar todo',
    decline: 'Solo esenciales',
    learnMore: 'Política de privacidad',
  },
  pt: {
    text: 'Usamos cookies para análise e publicidade personalizada. Você pode aceitar tudo ou usar apenas cookies essenciais.',
    accept: 'Aceitar tudo',
    decline: 'Apenas essenciais',
    learnMore: 'Política de privacidade',
  },
  tr: {
    text: 'Analiz ve kişiselleştirilmiş reklamlar için çerezler kullanıyoruz. Tümünü kabul edebilir veya yalnızca zorunlu çerezleri kullanabilirsiniz.',
    accept: 'Tümünü kabul et',
    decline: 'Yalnızca zorunlu',
    learnMore: 'Gizlilik Politikası',
  },
  hi: {
    text: 'हम एनालिटिक्स और वैयक्तिकृत विज्ञापनों के लिए कुकीज़ का उपयोग करते हैं। आप सभी स्वीकार कर सकते हैं या केवल आवश्यक कुकीज़ चुन सकते हैं।',
    accept: 'सभी स्वीकार करें',
    decline: 'केवल आवश्यक',
    learnMore: 'गोपनीयता नीति',
  },
  ru: {
    text: 'Мы используем cookie для аналитики и персонализированной рекламы. Вы можете принять все или использовать только необходимые.',
    accept: 'Принять все',
    decline: 'Только необходимые',
    learnMore: 'Политика конфиденциальности',
  },
};

const langKey = (lang in copy) ? lang : 'en';
const c = copy[langKey];
const privacyHref = lang === 'en' ? '/privacy/' : `/${lang}/privacy/`;
---

<div id="cookie-banner" class="cookie-banner" aria-live="polite" role="region" aria-label="Cookie consent">
  <div class="cookie-inner">
    <p class="cookie-text">
      {c.text}
      {' '}
      <a href={privacyHref} class="cookie-link">{c.learnMore}</a>
    </p>
    <div class="cookie-actions">
      <button id="cookie-decline" class="cookie-btn cookie-btn--ghost">{c.decline}</button>
      <button id="cookie-accept" class="cookie-btn cookie-btn--primary">{c.accept}</button>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: var(--color-bg-card);
    border-top: 1px solid var(--color-border);
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.12);
    padding: 16px 24px;
    transform: translateY(0);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .cookie-banner.hidden {
    transform: translateY(110%);
    opacity: 0;
    pointer-events: none;
  }

  .cookie-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .cookie-text {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
    flex: 1;
    min-width: 240px;
  }

  .cookie-link {
    color: var(--color-primary);
    text-decoration: underline;
    white-space: nowrap;
  }

  .cookie-actions {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
  }

  .cookie-btn {
    padding: 9px 20px;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }

  .cookie-btn--primary {
    background: var(--color-primary);
    color: #fff;
  }

  .cookie-btn--primary:hover {
    background: var(--color-primary-hover);
  }

  .cookie-btn--ghost {
    background: transparent;
    border-color: var(--color-border);
    color: var(--color-text-secondary);
  }

  .cookie-btn--ghost:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .cookie-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }

    .cookie-actions {
      width: 100%;
    }

    .cookie-btn {
      flex: 1;
      text-align: center;
    }
  }
</style>

<script>
  const COOKIE_KEY = 'cc_consent';
  const banner = document.getElementById('cookie-banner');

  function hasConsent(): boolean {
    try {
      return localStorage.getItem(COOKIE_KEY) !== null;
    } catch {
      return true; // if storage unavailable, don't show banner
    }
  }

  function setConsent(value: 'all' | 'essential'): void {
    try {
      localStorage.setItem(COOKIE_KEY, value);
    } catch {}
  }

  // Enable / disable Google Ads personalisation based on consent
  function applyConsent(value: 'all' | 'essential'): void {
    if (typeof window.gtag === 'function') {
      if (value === 'all') {
        window.gtag('consent', 'update', {
          ad_storage: 'granted',
          analytics_storage: 'granted',
          ad_personalization: 'granted',
          ad_user_data: 'granted',
        });
      } else {
        window.gtag('consent', 'update', {
          ad_storage: 'denied',
          analytics_storage: 'granted',
          ad_personalization: 'denied',
          ad_user_data: 'denied',
        });
      }
    }
  }

  // On page load: restore consent or show banner
  if (hasConsent()) {
    banner?.classList.add('hidden');
    const saved = localStorage.getItem(COOKIE_KEY) as 'all' | 'essential';
    applyConsent(saved ?? 'essential');
  }

  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    setConsent('all');
    applyConsent('all');
    banner?.classList.add('hidden');
  });

  document.getElementById('cookie-decline')?.addEventListener('click', () => {
    setConsent('essential');
    applyConsent('essential');
    banner?.classList.add('hidden');
  });
</script>
