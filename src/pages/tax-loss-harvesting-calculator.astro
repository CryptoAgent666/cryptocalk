---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.tsx';
import LanguageSwitcher from '../components/LanguageSwitcher.tsx';
import TaxLossHarvestingCalculator from '../components/TaxLossHarvestingCalculator.tsx';
import { Calculator, ChevronRight, ArrowLeft } from 'lucide-react';
import SiteFooter from '../components/SiteFooter.astro';
import ShareCalculator from '../components/ShareCalculator.astro';
import '../styles/calculator-page.css';

const buildDate = new Date().toISOString().split('T')[0];
---

<Layout
  title="Tax Loss Harvesting Calculator"
  description="Identify harvestable crypto losses to offset capital gains and estimate tax savings across your portfolio."
  lang="en"
  pageType="calculator"
>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">
        <Calculator size={24} />
        <span class="logo-text">Crypto<b>Calk</b></span>
      </a>
      <nav class="header-actions" aria-label="Main navigation">
        <a href="/" class="header-link">
          <ArrowLeft size={14} />
          All Calculators
        </a>
        <LanguageSwitcher client:idle currentLang="en" currentPath="/tax-loss-harvesting-calculator" />
        <ThemeToggle client:idle />
      </nav>
    </div>
  </header>

  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="section-container">
        <a href="/">Home</a>
        <ChevronRight size={12} />
        <a href="/calculators/tax-reporting/">Tax & Reporting</a>
        <ChevronRight size={12} />
        <a href="/tax-loss-harvesting-calculator/" aria-current="page">Tax Loss Harvesting Calculator</a>
      </div>
    </nav>

    <section class="calculator-section">
      <div class="section-container">
        <div class="calc-header">
          <h1>Tax Loss Harvesting Calculator</h1>
          <p>Identify harvestable crypto losses to offset capital gains and estimate tax savings across your portfolio.</p>
          <div class="calc-byline">
            <a href="/about/" class="byline-link">
              <span class="byline-by">By</span>
              <span class="byline-name">Konstantin Iakovlev</span>
            </a>
            <span class="byline-sep">·</span>
            <span class="byline-date">Updated {buildDate}</span>
          </div>
        </div>

        <div class="calc-scope">
          <TaxLossHarvestingCalculator lang={'en'} client:load />
          <ShareCalculator lang="en" />
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>
