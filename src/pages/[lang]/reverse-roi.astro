---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import ReverseRoiCalculator from '../../components/ReverseRoiCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="reverse-roi"
  title="Reverse ROI Calculator"
  description="Work backwards from a target outcome to required entry, growth, and probability range."
>
  <ReverseRoiCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
