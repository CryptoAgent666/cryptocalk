---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import RiskRewardCalculator from '../../components/RiskRewardCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="risk-reward-calculator"
  title="Risk / Reward Calculator"
  description="Evaluate risk-to-reward structure and validate setup quality before execution."
>
  <RiskRewardCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
