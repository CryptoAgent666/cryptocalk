---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import BreakEvenCalculator from '../../components/BreakEvenCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="break-even-calculator"
  title="Break-Even Calculator"
  description="Find the exact break-even point after fees, losses, or adverse price movement."
>
  <BreakEvenCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
