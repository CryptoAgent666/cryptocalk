const c = content[lang];
---

<Layout
  title={c.pageTitle}
  description={c.metaDescription}
  lang={lang}
>
  <SiteHeader lang={lang} currentPath={`/${lang}/updates`} />
  <main id="main-content" class="updates-container">
    <header class="updates-header">
      <h1>{c.heading}</h1>
      <p>{c.subtitle}</p>
    </header>

    <div class="updates-content">
      {c.updates.map((update, i) => (
        <>
          {i > 0 && <div class="divider" />}
          <article class="update-entry">
            <div class="update-date">
              <time datetime={update.date}>{update.dateLabel}</time>
            </div>
            <h2>{update.title}</h2>
            <p set:html={update.body} />
            {update.items && (
              <ul>
                {update.items.map((item) => (
                  <li set:html={item} />
                ))}
              </ul>
            )}
            {update.cta && (
              <p><a href={update.cta.href} target="_blank" rel="noopener noreferrer" class="cta-link">{update.cta.text}</a></p>
            )}
            {update.footer && <p>{update.footer}</p>}
          </article>
        </>
      ))}
    </div>
  </main>
  <SiteFooter lang={lang} />
</Layout>

<style>
  .updates-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 60px 24px;
  }

  .updates-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .updates-header h1 {
    font-size: 2.8rem;
    font-weight: 800;
    margin-bottom: 16px;
    letter-spacing: -0.03em;
  }

  .updates-header p {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .updates-content {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .update-date {
    margin-bottom: 12px;
  }

  .update-date time {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .update-entry h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--color-text);
  }

  .update-entry p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 12px;
  }

  .update-entry strong {
    color: var(--color-text);
  }

  .update-entry ul {
    list-style: none;
    padding: 0;
    margin: 12px 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .update-entry ul li {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    padding-left: 20px;
    position: relative;
  }

  .update-entry ul li::before {
    content: '•';
    position: absolute;
    left: 4px;
    color: var(--color-primary);
    font-weight: 700;
  }

  .update-entry :global(a) {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .update-entry :global(a:hover) {
    text-decoration: underline;
  }

  .cta-link {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .cta-link:hover {
    text-decoration: underline;
  }

  .divider {
    height: 1px;
    background: var(--color-border);
    width: 30%;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .updates-header h1 {
      font-size: 2rem;
    }
  }
</style>
