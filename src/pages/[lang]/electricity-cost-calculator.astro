---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import ElectricityCostCalculator from '../../components/ElectricityCostCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="electricity-cost-calculator"
  title="Mining Electricity Cost Calculator"
  description="Calculate mining electricity consumption and operating cost by device count, power usage, uptime, and local energy price."
>
  <ElectricityCostCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
