---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import PortfolioCalculator from '../../components/PortfolioCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="portfolio-calculator"
  title="Portfolio Allocation Calculator"
  description="Plan portfolio weights, rebalance ranges, and concentration risk across assets."
>
  <PortfolioCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
