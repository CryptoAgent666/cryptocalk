---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import HashrateConverter from '../../components/HashrateConverter.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="hashrate-converter"
  title="Hashrate Converter"
  description="Convert mining hashrate units from H/s up to EH/s and compare typical ranges for ASIC and GPU hardware."
>
  <HashrateConverter slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
