---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import LoanCalculator from '../../components/LoanCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="loan-calculator"
  title="Crypto Loan Calculator"
  description="Estimate crypto-backed loan costs, collateral risk, and repayment outcomes across scenarios."
>
  <LoanCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
