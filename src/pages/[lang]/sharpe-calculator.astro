---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import SharpeCalculator from '../../components/SharpeCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="sharpe-calculator"
  title="Sharpe Ratio Calculator"
  description="Evaluate risk-adjusted portfolio performance using expected return, volatility, and risk-free rate."
>
  <SharpeCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
