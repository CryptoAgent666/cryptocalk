---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import TreynorCalculator from '../../components/TreynorCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="treynor-calculator"
  title="Treynor Ratio Calculator"
  description="Measure return per unit of market risk (beta) and benchmark strategy efficiency against the risk-free rate."
>
  <TreynorCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
