---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import MiningCalculator from '../../components/MiningCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="mining-calculator"
  title="Mining Calculator"
  description="Estimate mining profitability using hashrate, power cost, network conditions, and asset price assumptions."
>
  <MiningCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
