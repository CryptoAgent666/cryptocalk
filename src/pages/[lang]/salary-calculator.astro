---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import CryptoSalaryCalculator from '../../components/CryptoSalaryCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="salary-calculator"
  title="Crypto Salary Calculator"
  description="Estimate crypto salary allocation outcomes and compare with fiat baseline trajectories."
>
  <CryptoSalaryCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
