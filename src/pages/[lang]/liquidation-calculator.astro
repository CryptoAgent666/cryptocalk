---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import LiquidationCalculator from '../../components/LiquidationCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="liquidation-calculator"
  title="Liquidation Calculator"
  description="Calculate liquidation thresholds and distance-to-liquidation for leveraged long and short setups."
>
  <LiquidationCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
