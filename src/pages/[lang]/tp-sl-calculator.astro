---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import TpSlCalculator from '../../components/TpSlCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="tp-sl-calculator"
  title="TP / SL Calculator"
  description="Plan take-profit and stop-loss levels aligned with position size and risk budget."
>
  <TpSlCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
