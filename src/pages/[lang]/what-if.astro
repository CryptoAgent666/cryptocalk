---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import WhatIfCalculator from '../../components/WhatIfCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="what-if"
  title="What If Calculator"
  description="Backtest hypothetical crypto entries and evaluate opportunity cost and alternative outcomes."
>
  <WhatIfCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
