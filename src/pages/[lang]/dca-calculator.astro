---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import DCACalculator from '../../components/DCACalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="dca-calculator"
  title="DCA Calculator"
  description="Simulate dollar-cost averaging outcomes and compare structured accumulation strategies."
>
  <DCACalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
