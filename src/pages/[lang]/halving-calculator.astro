---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import HalvingCalculator from '../../components/HalvingCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="halving-calculator"
  title="Bitcoin Halving Calculator"
  description="Track halving cycles and model potential impact scenarios for mining and market expectations."
>
  <HalvingCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
