---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import InformationRatioCalculator from '../../components/InformationRatioCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="information-ratio-calculator"
  title="Information Ratio Calculator"
  description="Compare active portfolio performance versus a benchmark using active return and tracking error."
>
  <InformationRatioCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
