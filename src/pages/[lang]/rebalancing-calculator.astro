---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import RebalancingCalculator from '../../components/RebalancingCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="rebalancing-calculator"
  title="Portfolio Rebalancing Calculator"
  description="Calculate buy/sell actions to rebalance your crypto portfolio toward target allocations with optional buy-only mode."
>
  <RebalancingCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
