const c = content[lang];
const prefix = lang === 'en' ? '' : `/${lang}`;
---

<Layout
  title={c.pageTitle}
  description={c.metaDescription}
  lang={lang}
>
  <div class="about-container">
    <header class="about-header">
      <h1>{c.heading}</h1>
      <p>{c.subtitle}</p>
    </header>

    <div class="about-content">
      <section class="mission-section">
        <h2>{c.missionTitle}</h2>
        <p set:html={c.missionP1} />
        <p>{c.missionP2}</p>
      </section>

      <div class="divider"></div>

      <section class="author-section">
        <h2>{c.meetCreator}</h2>
        <div class="author-card">
          <div class="author-avatar-col">
            <img src="/images/author_avatar.jpg" alt="Konstantin Iakovlev" class="author-avatar" onerror="this.src='data:image/svg+xml;base64,'" />
            <div class="author-social">
              <a href={`${prefix}/contact`} class="btn-primary btn-sm">{c.contactMe}</a>
            </div>
            <div class="author-social-links">
              <a href="https://x.com/yakovlevka3" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)"><Twitter size={20} /></a>
              <a href="https://www.linkedin.com/in/konstantin-iakovlev/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><Linkedin size={20} /></a>
              <a href="https://www.instagram.com/iakovlevka/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><Instagram size={20} /></a>
            </div>
          </div>
          <div class="author-bio-col">
            <h3>Konstantin Iakovlev</h3>
            <span class="author-role">{c.role}</span>

            <p>{c.bio1}</p>

            <p>{c.bio2}</p>

            <ul class="author-highlights">
              <li>
                <div class="highlight-icon"><Briefcase size={18} /></div>
                <div>
                  <strong>{c.highlightFinanceTitle}</strong>
                  <span>{c.highlightFinanceDesc}</span>
                </div>
              </li>
              <li>
                <div class="highlight-icon"><Award size={18} /></div>
                <div>
                  <strong>{c.highlightSeoTitle}</strong>
                  <span>{c.highlightSeoDesc}</span>
                </div>
              </li>
              <li>
                <div class="highlight-icon"><Code size={18} /></div>
                <div>
                  <strong>{c.highlightCodeTitle}</strong>
                  <span>{c.highlightCodeDesc}</span>
                </div>
              </li>
              <li>
                <div class="highlight-icon"><Globe size={18} /></div>
                <div>
                  <strong>{c.highlightProjectsTitle}</strong>
                  <span set:html={c.highlightProjectsDesc} />
                </div>
              </li>
            </ul>
          </div>
        </div>
      </section>
    </div>
  </div>

  <SiteFooter lang={lang} />
</Layout>

<style>
  .about-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 24px;
  }
  .about-header {
    text-align: center;
    margin-bottom: 56px;
  }
  .about-header h1 {
    font-size: 2.8rem;
    font-weight: 800;
    margin-bottom: 16px;
    letter-spacing: -0.03em;
  }
  .about-header p {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .mission-section p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 16px;
  }
  .mission-section :global(strong) {
    color: var(--color-text);
  }

  h2 {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 24px;
    color: var(--color-text);
  }

  .divider {
    height: 1px;
    background: var(--color-border);
    width: 30%;
    margin: 10px auto;
  }

  .author-card {
    display: flex;
    gap: 40px;
    background: var(--color-bg-card);
