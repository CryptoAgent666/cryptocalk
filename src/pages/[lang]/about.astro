---
import Layout from '../../layouts/Layout.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { Mail, Briefcase, Code, Award, Twitter, Linkedin, Instagram, Globe } from 'lucide-react';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };

interface AboutContent {
  pageTitle: string;
  metaDescription: string;
  heading: string;
  subtitle: string;
  missionTitle: string;
  missionP1: string;
  missionP2: string;
  meetCreator: string;
  role: string;
  bio1: string;
  bio2: string;
  highlightFinanceTitle: string;
  highlightFinanceDesc: string;
  highlightSeoTitle: string;
  highlightSeoDesc: string;
  highlightCodeTitle: string;
  highlightCodeDesc: string;
  highlightProjectsTitle: string;
  highlightProjectsDesc: string;
  contactMe: string;
}

