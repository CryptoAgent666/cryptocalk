---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import AirdropCalculator from '../../components/AirdropCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="airdrop-calculator"
  title="Airdrop Value Calculator"
  description="Estimate gross and net airdrop value with tax impact and after-fee outcome scenarios."
>
  <AirdropCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
