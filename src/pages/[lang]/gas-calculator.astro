---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import GasFeeCalculator from '../../components/GasFeeCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="gas-calculator"
  title="Crypto Gas Calculator"
  description="Estimate gas costs across major EVM networks for swaps, transfers, and DeFi actions."
>
  <GasFeeCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
