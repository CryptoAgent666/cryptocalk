---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import SatoshiConverter from '../../components/SatoshiConverter.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="satoshi-converter"
  title="Satoshi Converter"
  description="Convert sats, BTC, and fiat values instantly for clear denomination planning."
>
  <SatoshiConverter slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
