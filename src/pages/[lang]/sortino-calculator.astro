---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import SortinoCalculator from '../../components/SortinoCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="sortino-calculator"
  title="Sortino Ratio Calculator"
  description="Measure risk-adjusted portfolio performance with downside-volatility focus using the Sortino ratio."
>
  <SortinoCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
