---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import RoiCalculator from '../../components/RoiCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="roi-calculator"
  title="ROI Calculator"
  description="Measure total and annualized ROI across different investment periods and assumptions."
>
  <RoiCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
