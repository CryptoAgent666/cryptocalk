---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import CryptoConverter from '../../components/CryptoConverter.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="converter"
  title="Crypto Converter"
  description="Convert crypto to fiat and between coins using live market references and practical comparison inputs."
>
  <CryptoConverter slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
