    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .header-link:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
    background-color: var(--color-bg-card-hover);
  }

  /* ===== Hero ===== */
  .hero {
    position: relative;
    padding: 80px 24px 60px;
    text-align: center;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
