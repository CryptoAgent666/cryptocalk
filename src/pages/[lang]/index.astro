    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-header);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 24px;
