---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import NftProfitCalculator from '../../components/NftProfitCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="nft-profit-calculator"
  title="NFT Profit Calculator"
  description="Calculate NFT trade profitability after marketplace fees, royalties, and network costs."
>
  <NftProfitCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
