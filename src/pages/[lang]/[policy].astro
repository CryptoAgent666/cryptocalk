export function getStaticPaths() {
  const langs: LocalizedLang[] = ['es', 'pt', 'tr', 'hi', 'ru'];
  const policies: PolicyKey[] = ['privacy', 'editorial-policy', 'methodology'];
  return langs.flatMap((lang) => policies.map((policy) => ({ params: { lang, policy } })));
}

const { lang, policy } = Astro.params as { lang: LocalizedLang; policy: PolicyKey };
const content = contentByPolicy[policy]?.[lang];

if (!content) {
  throw new Error(`Unsupported localized policy page: ${lang}/${policy}`);
}

const pageUrl = `https://cryptocalk.com/${lang}/${policy}/`;
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: content.heading,
  url: pageUrl,
  description: content.metaDescription,
  inLanguage: lang,
};
---

<Layout title={content.pageTitle} description={content.metaDescription} lang={lang}>
  <SiteHeader lang={lang} currentPath={`/${lang}/${policy}`} />
  <main id="main-content" class="policy-page">
    <article class="policy-card">
      <h1>{content.heading}</h1>
      <p class="meta">{content.updatedLabel}: {LAST_UPDATED}</p>

      <p>{content.intro}</p>

      {content.sections.map((section) => (
        <section>
          <h2>{section.heading}</h2>
          {section.paragraphs?.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
          {section.bullets && (
            <ul>
              {section.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          )}
          {section.links && (
            <ul>
              {section.links.map((link) => (
                <li><a href={link.href} target="_blank" rel="nofollow noopener noreferrer">{link.label}</a></li>
              ))}
            </ul>
          )}
        </section>
      ))}
    </article>
  </main>

  <SiteFooter lang={lang} />
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
</Layout>

<style>
  .policy-page {
    padding: 48px 20px 72px;
  }

  .policy-card {
    max-width: 860px;
    margin: 0 auto;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    padding: 34px 28px;
    line-height: 1.7;
  }

  h1 {
    margin: 0 0 8px;
    font-size: clamp(1.8rem, 2.8vw, 2.2rem);
    line-height: 1.2;
  }

  .meta {
    margin: 0 0 20px;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  h2 {
    margin-top: 28px;
    margin-bottom: 8px;
    font-size: 1.2rem;
    line-height: 1.3;
  }

  ul {
    margin: 8px 0 12px 20px;
    padding: 0;
  }

  a {
    color: var(--color-primary);
  }
</style>
