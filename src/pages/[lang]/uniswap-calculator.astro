---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import UniswapCalculator from '../../components/UniswapCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="uniswap-calculator"
  title="Uniswap Fee Calculator"
  description="Estimate Uniswap LP fee income, impermanent loss impact, break-even time, and net outcome for selected pool assumptions."
>
  <UniswapCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
