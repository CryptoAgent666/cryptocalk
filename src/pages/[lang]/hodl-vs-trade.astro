---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import HodlVsTradeCalculator from '../../components/HodlVsTradeCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="hodl-vs-trade"
  title="HODL vs Trade Calculator"
  description="Compare long-term holding and active trading outcomes under realistic friction assumptions."
>
  <HodlVsTradeCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
