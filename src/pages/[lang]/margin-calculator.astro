---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import MarginCalculator from '../../components/MarginCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="margin-calculator"
  title="Margin Calculator"
  description="Calculate required margin, maintenance levels, and collateral efficiency for leveraged positions."
>
  <MarginCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
