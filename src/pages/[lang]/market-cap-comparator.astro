---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import MarketCapComparator from '../../components/MarketCapComparator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="market-cap-comparator"
  title="Market Cap Comparator"
  description="Compare market cap scenarios and estimate hypothetical token prices under alternate cap assumptions."
>
  <MarketCapComparator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
