---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import CompoundInterestCalculator from '../../components/CompoundInterestCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="compound-calculator"
  title="Compound Interest Calculator (Crypto)"
  description="Project compound growth for crypto savings, staking, and yield strategies with recurring contributions."
>
  <CompoundInterestCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
