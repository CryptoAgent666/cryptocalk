---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import GasFeeCalculator from '../../components/GasFeeCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="gas-fee-calculator"
  title="Gas Fee Calculator"
  description="Estimate blockchain gas fees and compare network execution costs before confirming transactions."
>
  <GasFeeCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
