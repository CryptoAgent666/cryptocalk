---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import ProfitCalculator from '../../components/ProfitCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="profit-calculator"
  title="Crypto Profit Calculator"
  description="Calculate crypto profit, net return, and ROI with fee-aware assumptions."
>
  <ProfitCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
