---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import VestingCalculator from '../../components/VestingCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="vesting-calculator"
  title="Token Vesting Calculator"
  description="Model vesting unlock schedules and estimate circulating supply pressure over time."
>
  <VestingCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
