---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import PipCalculator from '../../components/PipCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="pip-calculator"
  title="Pip / Tick Value Calculator"
  description="Calculate pip and tick value impact on PnL to improve risk and execution planning."
>
  <PipCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
