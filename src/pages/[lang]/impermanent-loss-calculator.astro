---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import ImpermanentLossCalculator from '../../components/ImpermanentLossCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="impermanent-loss-calculator"
  title="Impermanent Loss Calculator"
  description="Measure impermanent loss and evaluate LP fee income versus passive holding alternatives."
>
  <ImpermanentLossCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
