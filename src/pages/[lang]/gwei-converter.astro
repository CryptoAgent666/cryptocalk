---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import GweiConverter from '../../components/GweiConverter.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="gwei-converter"
  title="Gwei Converter"
  description="Convert Wei, Gwei, and Ether units instantly with live ETH price and practical gas cost examples."
>
  <GweiConverter slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
