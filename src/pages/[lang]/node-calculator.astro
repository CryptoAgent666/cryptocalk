---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import NodeCalculator from '../../components/NodeCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="node-calculator"
  title="Validator Node Calculator"
  description="Model validator node economics using staked amount, APR, commission, uptime, and infrastructure costs."
>
  <NodeCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
