---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import TaxCalculator from '../../components/TaxCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="tax-calculator"
  title="Crypto Tax Calculator"
  description="Estimate capital gains tax impact and compare post-tax outcomes across scenarios."
>
  <TaxCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
