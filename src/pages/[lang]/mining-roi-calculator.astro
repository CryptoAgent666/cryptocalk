---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import MiningRoiCalculator from '../../components/MiningRoiCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="mining-roi-calculator"
  title="Mining ROI Calculator"
  description="Model mining hardware return on investment with scenario analysis for revenue, costs, and break-even timing."
>
  <MiningRoiCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
