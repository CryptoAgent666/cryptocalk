---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import BridgeComparator from '../../components/BridgeComparator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="bridge-comparator"
  title="Bridge Cost Comparator"
  description="Compare crypto bridge routes by estimated total fee, speed, and security score across major L2 and multichain bridges."
>
  <BridgeComparator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
