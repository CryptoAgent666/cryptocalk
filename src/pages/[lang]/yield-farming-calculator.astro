---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import YieldFarmingCalculator from '../../components/YieldFarmingCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="yield-farming-calculator"
  title="Yield Farming Calculator"
  description="Estimate farming returns after APY, IL, and fee drag under realistic assumptions."
>
  <YieldFarmingCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
