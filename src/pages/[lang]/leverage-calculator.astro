---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import LeverageCalculator from '../../components/LeverageCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="leverage-calculator"
  title="Leverage Calculator"
  description="Model leveraged exposure and understand how gains, losses, and liquidation risk scale with leverage."
>
  <LeverageCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
