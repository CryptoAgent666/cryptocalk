---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import InflationHedgeCalculator from '../../components/InflationHedgeCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="inflation-hedge"
  title="Inflation Hedge Calculator"
  description="Compare inflation pressure versus crypto and traditional assets under multiple macro assumptions."
>
  <InflationHedgeCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
