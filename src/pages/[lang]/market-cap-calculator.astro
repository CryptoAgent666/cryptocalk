---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import MarketCapCalculator from '../../components/MarketCapCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="market-cap-calculator"
  title="Market Cap Calculator"
  description="Calculate token price from market cap and supply, or market cap from token price, with live crypto reference data."
>
  <MarketCapCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
