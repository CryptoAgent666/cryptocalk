---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import ApyAprCalculator from '../../components/ApyAprCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="apy-apr-calculator"
  title="APY vs APR Calculator"
  description="Compare APY and APR correctly and estimate compounding effects over your selected horizon."
>
  <ApyAprCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
