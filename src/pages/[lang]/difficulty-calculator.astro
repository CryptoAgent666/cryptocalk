---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import DifficultyEstimatorCalculator from '../../components/DifficultyEstimatorCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="difficulty-calculator"
  title="Mining Difficulty Estimator"
  description="Estimate how the next mining difficulty adjustment may impact your projected revenue and profitability."
>
  <DifficultyEstimatorCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
