interface StaticPathProps {
  canonicalSlug: SpecCalculatorSlug;
  localizedSlug: string;
}

export function getStaticPaths() {
  return NON_DEFAULT_LANGS.flatMap((lang) =>
    SPEC_CALCULATOR_SLUGS.map((canonicalSlug) => ({
      params: {
        lang,
        slug: getLocalizedSlug(canonicalSlug, lang),
      },
      props: {
        canonicalSlug,
        localizedSlug: getLocalizedSlug(canonicalSlug, lang),
      } satisfies StaticPathProps,
    }))
  );
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const { canonicalSlug, localizedSlug } = Astro.props as StaticPathProps;

const canonicalFromParam = getCanonicalSlug(slug, lang);
const canonicalRouteSlug = (canonicalFromParam || canonicalSlug) as SpecCalculatorSlug;
const routeDef = ALIAS_DEFINITIONS[canonicalRouteSlug];

if (!routeDef) {
  throw new Error(`Unknown localized calculator slug: ${slug} (${lang})`);
}

const pagePath = `/${lang}/${localizedSlug}`;
const description = `Free ${routeDef.title}. Calculate crypto outcomes instantly with transparent assumptions and updated market data.`;
