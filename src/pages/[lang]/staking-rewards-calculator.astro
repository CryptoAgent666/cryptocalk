---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import StakingRewardsCalculator from '../../components/StakingRewardsCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="staking-rewards-calculator"
  title="Staking Rewards Calculator"
  description="Estimate staking rewards, compounding outcomes, and validator fee impact over time."
>
  <StakingRewardsCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
