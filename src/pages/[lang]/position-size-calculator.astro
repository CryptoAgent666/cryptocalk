---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import PositionSizeCalculator from '../../components/PositionSizeCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="position-size-calculator"
  title="Position Size Calculator"
  description="Define position size from account risk so losses stay controlled by design."
>
  <PositionSizeCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
