---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import CompoundInterestCalculator from '../../components/CompoundInterestCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="compound-interest-calculator"
  title="Compound Interest Calculator"
  description="Project long-term crypto growth using compounding frequency, contributions, and yield assumptions."
>
  <CompoundInterestCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
