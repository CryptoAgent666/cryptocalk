---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import FundingRateCalculator from '../../components/FundingRateCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="funding-rate-calculator"
  title="Funding Rate Calculator"
  description="Estimate perpetual funding costs across holding periods and position sizes."
>
  <FundingRateCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
