---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import DvaCalculator from '../../components/DvaCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="dva-calculator"
  title="Dollar Value Averaging Calculator"
  description="Compare Dollar Value Averaging vs DCA — DVA adjusts investment amounts based on portfolio performance."
>
  <DvaCalculator slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
