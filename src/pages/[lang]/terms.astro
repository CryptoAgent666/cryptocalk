const c = content[lang];
---

<Layout
  title={c.pageTitle}
  description={c.metaDescription}
  lang={lang}
>
  <div class="legal-container">
    <header class="legal-header">
      <h1>{c.heading}</h1>
      <p>{c.lastUpdated}</p>
    </header>

    <div class="legal-content">
      {c.sections.map((section) => (
        <Fragment>
          <h2>{section.title}</h2>
          {section.paragraphs.map((p) => (
            <p>{p}</p>
          ))}
          {section.bullets && (
            <ul>
              {section.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          )}
        </Fragment>
      ))}
    </div>
  </div>
  <SiteFooter lang={lang} />
</Layout>

<style>
  .legal-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 60px 24px;
  }
  .legal-header {
    text-align: center;
    margin-bottom: 48px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-border);
  }
  .legal-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 12px;
  }
  .legal-header p {
    color: var(--color-text-muted);
  }
  .legal-content {
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
  .legal-content h2 {
    color: var(--color-text);
    font-size: 1.5rem;
    font-weight: 700;
    margin: 40px 0 16px;
  }
  .legal-content p {
    margin-bottom: 16px;
  }
  .legal-content ul {
    margin-bottom: 24px;
    padding-left: 24px;
  }
  .legal-content li {
    margin-bottom: 8px;
  }
  .legal-content a {
    color: var(--color-primary);
    text-decoration: none;
  }
  .legal-content a:hover {
    text-decoration: underline;
  }
</style>
