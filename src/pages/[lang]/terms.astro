    ],
  },
  pt: {
    pageTitle: 'Termos de Serviço | CryptoCalk',
    metaDescription: 'Termos de serviço e aviso legal para uso das calculadoras do CryptoCalk.',
    heading: 'Termos de Serviço',
    lastUpdated: 'Última atualização: 24 de fevereiro de 2026',
    sections: [
      { title: '1. Introdução', paragraphs: ['Bem-vindo ao CryptoCalk. Ao acessar ou usar nosso site (cryptocalk.com) e nossas calculadoras, você concorda com estes Termos de Serviço. Se não concordar, não use nosso site.'] },
