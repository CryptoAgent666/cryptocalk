---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import TimestampConverter from '../../components/TimestampConverter.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="timestamp-converter"
  title="Unix Timestamp Converter"
  description="Convert Unix timestamp to date/time and date/time to Unix format with UTC/local display and block-time estimates."
>
  <TimestampConverter slot="calculator" lang={lang} client:load />
</LocalizedCalculatorPage>
