---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import GpuMiningCalculator from '../../components/GpuMiningCalculator.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="gpu-mining-calculator"
  title="GPU Mining Calculator"
  description="Estimate GPU mining profitability with live assumptions for hashrate, power draw, electricity rates, and pool fees."
>
  <GpuMiningCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
