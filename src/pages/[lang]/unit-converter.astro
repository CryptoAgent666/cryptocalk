---
import LocalizedCalculatorPage from '../../components/LocalizedCalculatorPage.astro';
import CryptoUnitConverter from '../../components/CryptoUnitConverter.tsx';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return ['es', 'pt', 'tr', 'hi', 'ru'].map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Lang };
---

<LocalizedCalculatorPage
  lang={lang}
  slug="unit-converter"
  title="Crypto Unit Converter"
  description="Convert denomination units for BTC, ETH, SOL, and USDT including satoshi, gwei, lamport, and micro units."
>
  <CryptoUnitConverter slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>
