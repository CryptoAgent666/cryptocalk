const c = content[lang];
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.pageTitle,
  description: c.metaDescription,
  url: `https://cryptocalk.com/${lang}/contact/`,
  inLanguage: lang,
  dateModified: '2026-02-26',
};
---

<Layout
  title={c.pageTitle}
  description={c.metaDescription}
  lang={lang}
>
  <SiteHeader lang={lang} currentPath={`/${lang}/contact`} />
  <div class="page-container">
    <header class="page-header">
      <h1>{c.heading}</h1>
      <p>{c.subtitle}</p>
    </header>

    <div class="content-wrapper">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>{c.getInTouch}</h2>
          <p>{c.introText}</p>

          <ul class="contact-details">
            <li>
              <Mail class="icon" size={20} />
              <div>
                <strong>{c.emailLabel}</strong>
                <a href="mailto:support@cryptocalk.com">support@cryptocalk.com</a>
                <span class="hint">{c.emailHint}</span>
              </div>
            </li>
            <li>
              <Clock class="icon" size={20} />
              <div>
                <strong>{c.responseLabel}</strong>
                <span>{c.responseText}</span>
              </div>
            </li>
          </ul>
        </div>

        <div class="contact-form-container">
          <h2>{c.sendMessage}</h2>
          <form
            class="contact-form js-contact-form"
            action="/api/contact"
            method="post"
            data-sending-text={c.sendingText}
            data-success-text={c.successText}
            data-error-text={c.errorText}
          >
            <input type="hidden" name="redirectTo" value={`/${lang}/contact/`} />
            <input type="hidden" name="formLocale" value={lang} />
            <div class="form-group honeypot" aria-hidden="true">
              <label for="company">Company</label>
              <input type="text" id="company" name="company" tabindex="-1" autocomplete="off" />
            </div>
            <div class="form-group">
              <label for="name">{c.nameLabel}</label>
              <input type="text" id="name" name="name" required placeholder={c.namePlaceholder} />
            </div>
            <div class="form-group">
              <label for="email">{c.emailFieldLabel}</label>
              <input type="email" id="email" name="email" required placeholder={c.emailPlaceholder} />
            </div>
            <div class="form-group">
              <label for="subject">{c.subjectLabel}</label>
              <select id="subject" name="subject" required>
                <option value={c.subjectGeneral}>{c.subjectGeneral}</option>
                <option value={c.subjectCalculator}>{c.subjectCalculator}</option>
                <option value={c.subjectBug}>{c.subjectBug}</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">{c.messageLabel}</label>
              <textarea id="message" name="message" rows="5" required placeholder={c.messagePlaceholder}></textarea>
            </div>
            <button type="submit" class="btn-primary">{c.sendButton}</button>
            <p class="form-status" data-form-status aria-live="polite"></p>
          </form>
        </div>
      </div>
    </div>
  </div>
  <SiteFooter lang={lang} />
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
</Layout>

<script is:inline>
  (() => {
    const form = document.querySelector('.js-contact-form');
    if (!(form instanceof HTMLFormElement)) return;

    const statusEl = form.querySelector('[data-form-status]');
    const submitButton = form.querySelector('button[type="submit"]');
    if (!(statusEl instanceof HTMLElement) || !(submitButton instanceof HTMLButtonElement)) return;

    const sendingText = form.dataset.sendingText || 'Sending...';
    const successText = form.dataset.successText || 'Thanks. Your message has been sent.';
    const errorText = form.dataset.errorText || 'Unable to send right now. Please try again later.';

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      submitButton.disabled = true;
      statusEl.textContent = sendingText;
      statusEl.className = 'form-status pending';

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });

        const payload = await response.json().catch(() => ({}));

        if (response.ok) {
          statusEl.textContent = typeof payload.message === 'string' ? payload.message : successText;
          statusEl.className = 'form-status success';
          form.reset();
          return;
        }

        statusEl.textContent = typeof payload.error === 'string' ? payload.error : errorText;
        statusEl.className = 'form-status error';
      } catch {
        statusEl.textContent = errorText;
        statusEl.className = 'form-status error';
      } finally {
        submitButton.disabled = false;
      }
    });
  })();
</script>

<style>
  .page-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 60px 24px;
  }
  .page-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 12px;
  }
  .page-header p {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: flex-start;
  }
  .contact-info h2, .contact-form-container h2 {
    font-size: 1.5rem;
    margin-bottom: 16px;
    font-weight: 700;
  }
  .contact-info p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 32px;
  }
  .contact-details {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .contact-details li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .contact-details :global(.icon) {
    color: var(--color-primary);
    margin-top: 4px;
  }
  .contact-details strong {
    display: block;
    margin-bottom: 4px;
    color: var(--color-text);
  }
  .contact-details a, .contact-details span {
    color: var(--color-text-secondary);
    text-decoration: none;
  }
  .contact-details a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }
  .hint {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 4px;
  }

  .contact-form-container {
    background: var(--color-bg-card);
    padding: 32px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-group label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .form-group input, .form-group select, .form-group textarea {
    padding: 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text);
    font-family: inherit;
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px var(--color-primary-light);
  }
  .btn-primary {
    padding: 14px;
    background: var(--color-primary);
    color: white;
    font-weight: 600;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-primary:hover {
    background: var(--color-primary-dark);
  }
  .btn-primary:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }
  .form-status {
    margin: 4px 0 0;
    min-height: 1.25em;
    font-size: 0.9rem;
  }
  .form-status.pending {
    color: var(--color-text-secondary);
  }
  .form-status.success {
    color: #1ea971;
  }
  .form-status.error {
    color: #d64545;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
