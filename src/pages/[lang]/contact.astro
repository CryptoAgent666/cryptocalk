    messagePlaceholder: 'Чем мы можем помочь?',
    sendButton: 'Отправить Сообщение',
  },
};

const c = content[lang];
---

<Layout
  title={c.pageTitle}
  description={c.metaDescription}
  lang={lang}
>
  <SiteHeader lang={lang} currentPath={`/${lang}/contact`} />
  <div class="page-container">
    <header class="page-header">
      <h1>{c.heading}</h1>
      <p>{c.subtitle}</p>
    </header>

    <div class="content-wrapper">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>{c.getInTouch}</h2>
          <p>{c.introText}</p>

          <ul class="contact-details">
            <li>
              <Mail class="icon" size={20} />
              <div>
                <strong>{c.emailLabel}</strong>
                <a href="mailto:support@cryptocalk.com">support@cryptocalk.com</a>
                <span class="hint">{c.emailHint}</span>
              </div>
            </li>
            <li>
              <Mail class="icon" size={20} />
              <div>
                <strong>{c.businessLabel}</strong>
                <a href="mailto:partners@cryptocalk.com">partners@cryptocalk.com</a>
              </div>
            </li>
            <li>
              <Clock class="icon" size={20} />
              <div>
                <strong>{c.responseLabel}</strong>
                <span>{c.responseText}</span>
              </div>
            </li>
          </ul>
        </div>

        <div class="contact-form-container">
          <h2>{c.sendMessage}</h2>
          <form class="contact-form" action="mailto:support@cryptocalk.com" method="post" enctype="text/plain">
            <div class="form-group">
              <label for="name">{c.nameLabel}</label>
              <input type="text" id="name" name="name" required placeholder={c.namePlaceholder} />
            </div>
            <div class="form-group">
              <label for="email">{c.emailFieldLabel}</label>
              <input type="email" id="email" name="email" required placeholder={c.emailPlaceholder} />
            </div>
            <div class="form-group">
              <label for="subject">{c.subjectLabel}</label>
              <select id="subject" name="subject" required>
                <option value={c.subjectGeneral}>{c.subjectGeneral}</option>
                <option value={c.subjectCalculator}>{c.subjectCalculator}</option>
                <option value={c.subjectBug}>{c.subjectBug}</option>
                <option value={c.subjectPartnership}>{c.subjectPartnership}</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">{c.messageLabel}</label>
              <textarea id="message" name="message" rows="5" required placeholder={c.messagePlaceholder}></textarea>
            </div>
            <button type="submit" class="btn-primary">{c.sendButton}</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <SiteFooter lang={lang} />
</Layout>

<style>
  .page-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 60px 24px;
  }
  .page-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 12px;
  }
  .page-header p {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: flex-start;
  }
  .contact-info h2, .contact-form-container h2 {
    font-size: 1.5rem;
    margin-bottom: 16px;
    font-weight: 700;
  }
  .contact-info p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 32px;
  }
  .contact-details {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .contact-details li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .contact-details :global(.icon) {
    color: var(--color-primary);
    margin-top: 4px;
  }
  .contact-details strong {
    display: block;
    margin-bottom: 4px;
    color: var(--color-text);
  }
  .contact-details a, .contact-details span {
    color: var(--color-text-secondary);
    text-decoration: none;
  }
  .contact-details a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }
  .hint {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 4px;
  }

  .contact-form-container {
    background: var(--color-bg-card);
    padding: 32px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-group label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .form-group input, .form-group select, .form-group textarea {
    padding: 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text);
    font-family: inherit;
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px var(--color-primary-light);
  }
  .btn-primary {
    padding: 14px;
    background: var(--color-primary);
    color: white;
    font-weight: 600;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-primary:hover {
    background: var(--color-primary-dark);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
