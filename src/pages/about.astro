---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { Mail, Briefcase, Code, Twitter, Linkedin, Instagram, Globe } from 'lucide-react';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cryptocalk.com/' },
    { '@type': 'ListItem', position: 2, name: 'About Us', item: 'https://cryptocalk.com/about/' },
  ],
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  name: 'About Us — CryptoCalk',
  description:
    'Learn about CryptoCalk and Konstantin Iakovlev — founder, full-stack developer and SEO expert behind 108 free crypto calculators in 6 languages.',
  url: 'https://cryptocalk.com/about/',
  inLanguage: 'en',
  dateModified: '2026-05-11',
  mainEntity: {
    '@type': 'Person',
    '@id': 'https://cryptocalk.com/about/#founder',
    name: 'Konstantin Iakovlev',
    alternateName: 'Konstantin Yakovlev',
    jobTitle: 'Founder, Lead Developer & SEO Specialist',
    description:
      'Full-stack developer with 10+ years of professional experience in finance, cryptocurrency markets, and SEO since 2017. Builds fast, accurate cryptocurrency calculators using Astro, React, and TypeScript. Founder of CryptoCalk (108 calculators, 1,241 pages, 6 languages), zanimaem.kz (Kazakhstan loan comparison platform), and calk.kz (Kazakhstan financial calculators).',
    url: 'https://cryptocalk.com/about/',
    image: 'https://cryptocalk.com/images/author_avatar.jpg',
    nationality: 'Kazakhstani',
    sameAs: [
      'https://x.com/yakovlevka3',
      'https://www.linkedin.com/in/konstantin-iakovlev/',
      'https://www.instagram.com/iakovlevka/',
      'https://zanimaem.kz',
      'https://calk.kz',
    ],
    worksFor: {
      '@type': 'Organization',
      '@id': 'https://cryptocalk.com/#organization',
      name: 'CryptoCalk',
      url: 'https://cryptocalk.com',
    },
    owns: [
      { '@type': 'WebSite', name: 'CryptoCalk', url: 'https://cryptocalk.com' },
      { '@type': 'WebSite', name: 'zanimaem.kz', url: 'https://zanimaem.kz' },
      { '@type': 'WebSite', name: 'calk.kz', url: 'https://calk.kz' },
    ],
    knowsAbout: [
      'Cryptocurrency',
      'Bitcoin',
      'Ethereum',
      'DeFi (Decentralized Finance)',
      'Crypto Trading',
      'Crypto Mining',
      'Crypto Tax Calculation',
      'Financial Calculators',
      'Quantitative Finance',
      'Web Development',
      'Astro Framework',
      'React',
      'TypeScript',
      'Technical SEO',
      'On-Page SEO',
      'Internationalization (i18n)',
    ],
    knowsLanguage: ['English', 'Russian', 'Spanish', 'Portuguese', 'Turkish', 'Hindi'],
  },
};
---

<Layout
  title="About CryptoCalk | Free Crypto Calculators"
  description="Meet Konstantin Iakovlev, the developer behind CryptoCalk — 93 free, fast, and accurate cryptocurrency calculators in 6 languages."
  lang="en"
>
  <SiteHeader lang="en" currentPath="/about" />
  <main id="main-content" class="about-container">
    <header class="about-header">
      <h1>About CryptoCalk</h1>
      <p>Building the fastest, most reliable financial tools for the crypto community.</p>
    </header>

    <div class="about-content">
      <section class="mission-section">
        <h2>Our Mission</h2>
        <p>Traders, investors, and researchers need reliable numbers before they act — whether that means sizing a position, projecting <a href="/staking-calculator/" class="project-link">staking yields</a>, or estimating <a href="/tax-calculator/" class="project-link">tax exposure</a>. CryptoCalk provides <strong>93 specialized calculators</strong> — from <a href="/dca-calculator/" class="project-link">DCA projections</a> and <a href="/liquidation-calculator/" class="project-link">liquidation prices</a> to <a href="/mining-calculator/" class="project-link">mining profitability</a> — all fast, accurate, and free to use without an account.</p>
        <p>Every calculator runs entirely in your browser. Your numbers stay on your device. The formulas are transparent, the interface is clean, and the site is available in 6 languages for users in over 50 countries.</p>
      </section>

      <div class="divider"></div>

      <section class="author-section">
        <h2>Meet the Creator</h2>
        <div class="author-card">
          <div class="author-avatar-col">
            <img src="/images/author_avatar.jpg" alt="Konstantin Iakovlev" class="author-avatar" loading="lazy" width="120" height="120" onerror="this.src='data:image/svg+xml;base64,'" />
            <div class="author-social">
              <a href="/contact/" class="btn-primary btn-sm">Contact Me</a>
            </div>
            <div class="author-social-links">
              <a href="https://x.com/yakovlevka3" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)"><Twitter size={20} /></a>
              <a href="https://www.linkedin.com/in/konstantin-iakovlev/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><Linkedin size={20} /></a>
              <a href="https://www.instagram.com/iakovlevka/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><Instagram size={20} /></a>
            </div>
          </div>
          <div class="author-bio-col">
            <h3>Konstantin Iakovlev</h3>
            <span class="author-role">Founder & Lead Developer</span>

            <p>Developer with 10+ years at the intersection of finance and technology. I have been building financial web products since the early 2010s — first in traditional lending, then in cryptocurrency since 2017. CryptoCalk is the product of everything I have learned about what people actually need when making financial decisions.</p>

            <p>Previously I created <a href="https://zanimaem.kz" target="_blank" rel="noopener noreferrer" class="project-link">zanimaem.kz</a> (Kazakhstan's leading financial comparison platform) and <a href="https://calk.kz" target="_blank" rel="noopener noreferrer" class="project-link">calk.kz</a> (multi-purpose calculator platform). CryptoCalk is built with Astro, React, and TypeScript — every page is statically generated and every calculation runs client-side for maximum speed and privacy.</p>

            <ul class="author-highlights">
              <li>
                <div class="highlight-icon"><Briefcase size={18} /></div>
                <div>
                  <strong>Finance & Crypto</strong>
                  <span>10+ years working with financial instruments — yields, margins, liquidation mechanics, and tax structures. Active in crypto markets since 2017.</span>
                </div>
              </li>
              <li>
                <div class="highlight-icon"><Code size={18} /></div>
                <div>
                  <strong>Web Development</strong>
                  <span>Astro, React, TypeScript. Sub-second page loads, mobile-first design, 93 calculators across 6 languages.</span>
                </div>
              </li>
              <li>
                <div class="highlight-icon"><Globe size={18} /></div>
                <div>
                  <strong>Other Projects</strong>
                  <span>Creator of <a href="https://zanimaem.kz" target="_blank" rel="noopener noreferrer" class="project-link">zanimaem.kz</a> and <a href="https://calk.kz" target="_blank" rel="noopener noreferrer" class="project-link">calk.kz</a>.</span>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <div class="divider"></div>

      <section class="mission-section">
        <h2>Why Trust CryptoCalk</h2>
        <ul class="trust-list">
          <li><strong>Transparent calculations</strong> — every formula is visible. You can verify the math yourself.</li>
          <li><strong>Privacy-first</strong> — all calculations run in your browser. Nothing is sent to our servers.</li>
          <li><strong>Regularly updated</strong> — formulas, tax rules, and market data are audited and refreshed on an ongoing basis.</li>
          <li><strong>Used worldwide</strong> — available in 6 languages, serving traders and investors in 50+ countries.</li>
        </ul>
      </section>
    </div>
  </main>
  <SiteFooter lang="en" />
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style>
  .about-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 24px;
  }
  .about-header {
    text-align: center;
    margin-bottom: 56px;
  }
  .about-header h1 {
    font-size: 2.8rem;
    font-weight: 800;
    margin-bottom: 16px;
    letter-spacing: -0.03em;
  }
  .about-header p {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .mission-section p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 16px;
  }
  .mission-section strong {
    color: var(--color-text);
  }

  .trust-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .trust-list li {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    padding-left: 24px;
    position: relative;
  }
  .trust-list li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  h2 {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 24px;
    color: var(--color-text);
  }

  .divider {
    height: 1px;
    background: var(--color-border);
    width: 30%;
    margin: 10px auto;
  }

  .author-card {
    display: flex;
    gap: 40px;
    background: var(--color-bg-card);
    padding: 40px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
  }

  .author-avatar-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
    width: 200px;
  }

  .author-avatar {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--color-bg);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    background-color: var(--color-bg-tertiary); /* fallback for svg icon */
    padding: 2px;
  }

  .author-social {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .btn-sm {
    padding: 10px 20px;
    font-size: 0.9rem;
    border-radius: 999px;
    text-decoration: none;
    background: var(--color-primary);
    color: white;
    font-weight: 600;
    transition: background 0.2s;
  }
  .btn-sm:hover {
    background: var(--color-primary-dark);
  }

  .author-social-links {
    display: flex;
    gap: 16px;
    margin-top: 12px;
    justify-content: center;
  }
  .author-social-links a {
    color: var(--color-text-secondary);
    transition: color 0.2s ease, transform 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
  }
  .author-social-links a:hover {
    color: var(--color-primary);
    transform: translateY(-2px);
  }

  .project-link {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }
  .project-link:hover {
    text-decoration: underline;
  }

  .author-bio-col {
    flex: 1;
  }

  .author-bio-col h3 {
    font-size: 1.6rem;
    margin-bottom: 4px;
  }

  .author-role {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 20px;
  }

  .author-bio-col p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .author-highlights {
    list-style: none;
    padding: 0;
    margin: 32px 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .author-highlights li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .highlight-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .author-highlights strong {
    display: block;
    color: var(--color-text);
    margin-bottom: 4px;
    font-size: 0.95rem;
  }

  .author-highlights span {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .author-card {
      flex-direction: column;
      align-items: center;
      padding: 24px;
      gap: 32px;
    }
    .author-avatar-col {
      width: 100%;
    }
    .author-bio-col {
      text-align: center;
    }
    .author-highlights li {
      text-align: left;
    }
  }
</style>
