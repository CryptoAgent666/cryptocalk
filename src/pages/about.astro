---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { Mail, Briefcase, Code, Award, Twitter, Linkedin, Instagram, Globe } from 'lucide-react';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cryptocalk.com/' },
    { '@type': 'ListItem', position: 2, name: 'About', item: 'https://cryptocalk.com/about/' },
  ],
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  name: 'About Us | CryptoCalk',
  description:
    'Learn about CryptoCalk and Konstantin Iakovlev, the founder and developer behind our suite of fast, accurate crypto calculators.',
  url: 'https://cryptocalk.com/about/',
  inLanguage: 'en',
  dateModified: '2026-03-18',
  mainEntity: {
    '@type': 'Person',
    '@id': 'https://cryptocalk.com/about/#founder',
    name: 'Konstantin Iakovlev',
    jobTitle: 'Founder & Lead Developer',
    description:
      'Passionate developer with a deep professional background in finance, cryptocurrency, and SEO. Creator of CryptoCalk.',
    url: 'https://cryptocalk.com/about/',
    image: 'https://cryptocalk.com/images/author_avatar.jpg',
    sameAs: [
      'https://x.com/yakovlevka3',
      'https://www.linkedin.com/in/konstantin-iakovlev/',
      'https://www.instagram.com/iakovlevka/',
    ],
    worksFor: {
      '@type': 'Organization',
      name: 'CryptoCalk',
      url: 'https://cryptocalk.com',
    },
    knowsAbout: ['Cryptocurrency', 'Financial Calculators', 'Web Development', 'SEO', 'DeFi', 'Crypto Trading'],
  },
};
---

<Layout
  title="About CryptoCalk — Free Crypto Calculators by Konstantin Iakovlev"
  description="Meet Konstantin Iakovlev, the developer behind CryptoCalk — 50+ free, fast, and accurate cryptocurrency calculators. No signup, no ads, no tricks."
  lang="en"
>
  <SiteHeader lang="en" currentPath="/about" />
  <div class="about-container">
    <header class="about-header">
      <h1>About CryptoCalk</h1>
      <p>Building the fastest, most reliable financial tools for the crypto community.</p>
    </header>

    <div class="about-content">
      <section class="mission-section">
        <h2>Our Mission</h2>
        <p>CryptoCalk was built with a single goal: to provide the cryptocurrency community with <strong>lightning-fast, accurate, and privacy-focused</strong> calculation tools. In a space cluttered with slow, ad-heavy websites, we believed there was a need for a clean, professional alternative that respects both your time and your data.</p>
        <p>Whether you are calculating mining profitability, forecasting your DCA strategy, estimating your tax liability, or modeling liquidation risk on a leveraged position, our 50+ tools are designed to load instantly and run entirely in your browser. No signups, no data harvesting, no third-party tracking — just transparent math backed by real-time market data.</p>
        <p>Every formula we use is visible and documented. Every calculation happens client-side. We believe that financial tools should empower users with clarity, not lock them behind paywalls or obscure their methodology. That principle drives every feature we build.</p>
      </section>

      <div class="divider"></div>

      <section class="author-section">
        <h2>Meet the Creator</h2>
        <div class="author-card">
          <div class="author-avatar-col">
            <img src="/images/author_avatar.jpg" alt="Konstantin Iakovlev" class="author-avatar" loading="lazy" width="120" height="120" onerror="this.src='data:image/svg+xml;base64,'" />
            <div class="author-social">
              <a href="/contact/" class="btn-primary btn-sm">Contact Me</a>
            </div>
            <div class="author-social-links">
              <a href="https://x.com/yakovlevka3" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)"><Twitter size={20} /></a>
              <a href="https://www.linkedin.com/in/konstantin-iakovlev/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><Linkedin size={20} /></a>
              <a href="https://www.instagram.com/iakovlevka/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><Instagram size={20} /></a>
            </div>
          </div>
          <div class="author-bio-col">
            <h3>Konstantin Iakovlev</h3>
            <span class="author-role">Founder & Lead Developer</span>

            <p>I'm Konstantin, a developer and financial technologist with over a decade of experience at the intersection of finance, web development, and data-driven decision making. I have been actively involved in cryptocurrency markets since 2017 — trading, mining, staking, and building tools that solve real problems I encountered as a market participant.</p>

            <p>Before CryptoCalk, I built and scaled two financial platforms in the CIS market: <a href="https://zanimaem.kz" target="_blank" rel="noopener noreferrer" class="project-link">zanimaem.kz</a>, Kazakhstan's leading financial product comparison service, and <a href="https://calk.kz" target="_blank" rel="noopener noreferrer" class="project-link">calk.kz</a>, a multi-purpose calculator platform used by thousands of users monthly. Both projects required deep expertise in financial modeling, regulatory compliance, and high-performance web architecture — skills that directly informed how CryptoCalk was designed.</p>

            <p>I noticed that most crypto calculators online were either outdated, painfully slow, or buried under intrusive ads and affiliate widgets. Many also used opaque formulas or returned inaccurate results for edge cases like high-leverage liquidation or compounding across irregular intervals. CryptoCalk was my answer: an open, fast, and accurate toolkit that I would trust with my own capital decisions.</p>

            <ul class="author-highlights">
              <li>
                <div class="highlight-icon"><Briefcase size={18} /></div>
                <div>
                  <strong>Finance & Crypto Expertise</strong>
                  <span>Hands-on experience with spot and derivatives trading, DeFi yield strategies, mining operations, and tokenomics analysis since 2017. Every calculator reflects real trading scenarios, not textbook theory.</span>
                </div>
              </li>
              <li>
                <div class="highlight-icon"><Award size={18} /></div>
                <div>
                  <strong>Technical SEO & Content Architecture</strong>
                  <span>Specialized in structuring complex financial data into accessible, well-organized web content. Built multi-language platforms serving 6 languages with 750+ optimized pages.</span>
                </div>
              </li>
              <li>
                <div class="highlight-icon"><Code size={18} /></div>
                <div>
                  <strong>Modern Web Development</strong>
                  <span>Full-stack development with Astro, React, and TypeScript. Performance-first architecture delivering sub-second page loads, zero client-side dependencies for calculations, and full offline capability.</span>
                </div>
              </li>
              <li>
                <div class="highlight-icon"><Globe size={18} /></div>
                <div>
                  <strong>Proven Track Record</strong>
                  <span>Creator of <a href="https://zanimaem.kz" target="_blank" rel="noopener noreferrer" class="project-link">zanimaem.kz</a> and <a href="https://calk.kz" target="_blank" rel="noopener noreferrer" class="project-link">calk.kz</a> — established financial comparison and calculator platforms serving the Central Asian market.</span>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <div class="divider"></div>

      <section class="methodology-section">
        <h2>How We Build Our Calculators</h2>
        <p>Every calculator on CryptoCalk goes through a structured development process designed to ensure accuracy, usability, and relevance. We do not ship tools that produce numbers we cannot verify ourselves.</p>
        <p><strong>Formula verification.</strong> Each calculator's formulas are cross-referenced against established financial standards, exchange documentation, and academic sources. For trading tools, we validate outputs against real positions on major exchanges (Binance, Kraken, Bybit). For tax calculators, we align with IRS, HMRC, and ATO guidance on crypto capital gains treatment.</p>
        <p><strong>Real-time data integration.</strong> Calculators that depend on live market prices use a multi-provider fallback chain — CoinGecko, CryptoCompare, and CoinCap — ensuring data availability even if one API goes down. Historical price data is cached and validated against multiple sources before being used in simulations.</p>
        <p><strong>Edge case testing.</strong> We test every calculator against boundary conditions: zero values, extremely large numbers, negative scenarios, and high-leverage positions near liquidation. If a calculator can produce a misleading result under any realistic condition, we fix the formula or add explicit warnings before publishing.</p>
        <p><strong>Regular audits.</strong> Market conditions evolve — fee structures change, new DeFi protocols emerge, tax rules update. We review and update our tools on a rolling basis to ensure the assumptions and defaults remain current. Every calculator page shows a last-updated date so you know the content reflects recent conditions.</p>
      </section>

      <div class="divider"></div>

      <section class="trust-section">
        <h2>Why Trust CryptoCalk</h2>
        <p>Financial tools carry responsibility. When someone uses a calculator to decide whether to enter a $10,000 leveraged position or to estimate their tax bill, the output must be accurate and the methodology must be transparent. Here is how we earn that trust:</p>
        <ul class="trust-list">
          <li><strong>Open formulas.</strong> Every calculation is visible in the page source. We do not hide methodology behind a black box. If you want to verify our math, you can.</li>
          <li><strong>Client-side execution.</strong> All calculations run in your browser. No data is transmitted to our servers. Your financial inputs stay on your device.</li>
          <li><strong>No ads, no affiliate bias.</strong> CryptoCalk does not run display ads, sponsored placements, or affiliate links that could bias which tools we promote or how we present results.</li>
          <li><strong>No signup walls.</strong> Every tool is accessible immediately, in full, without registration. We do not gate features behind email collection.</li>
          <li><strong>Multi-language accessibility.</strong> Our calculators are available in 6 languages (English, Spanish, Portuguese, Turkish, Hindi, Russian) with localized content — not machine-translated stubs — to serve a global user base.</li>
          <li><strong>Regular updates.</strong> We actively maintain every calculator against evolving market conditions, exchange fee structures, and regulatory guidance.</li>
        </ul>
      </section>
    </div>
  </div>
  <SiteFooter lang="en" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
</Layout>

<style>
  .about-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 24px;
  }
  .about-header {
    text-align: center;
    margin-bottom: 56px;
  }
  .about-header h1 {
    font-size: 2.8rem;
    font-weight: 800;
    margin-bottom: 16px;
    letter-spacing: -0.03em;
  }
  .about-header p {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }
  
  .about-content {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  
  .mission-section p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 16px;
  }
  .mission-section strong {
    color: var(--color-text);
  }
  
  h2 {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 24px;
    color: var(--color-text);
  }
  
  .divider {
    height: 1px;
    background: var(--color-border);
    width: 30%;
    margin: 10px auto;
  }
  
  .author-card {
    display: flex;
    gap: 40px;
    background: var(--color-bg-card);
    padding: 40px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
  }
  
  .author-avatar-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
    width: 200px;
  }
  
  .author-avatar {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--color-bg);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    background-color: var(--color-bg-tertiary); /* fallback for svg icon */
    padding: 2px;
  }
  
  .author-social {
    width: 100%;
    display: flex;
    justify-content: center;
  }
  
  .btn-sm {
    padding: 10px 20px;
    font-size: 0.9rem;
    border-radius: 999px;
    text-decoration: none;
    background: var(--color-primary);
    color: white;
    font-weight: 600;
    transition: background 0.2s;
  }
  .btn-sm:hover {
    background: var(--color-primary-dark);
  }
  
  .author-social-links {
    display: flex;
    gap: 16px;
    margin-top: 12px;
    justify-content: center;
  }
  .author-social-links a {
    color: var(--color-text-secondary);
    transition: color 0.2s ease, transform 0.2s ease;
  }
  .author-social-links a:hover {
    color: var(--color-primary);
    transform: translateY(-2px);
  }
  
  .project-link {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }
  .project-link:hover {
    text-decoration: underline;
  }
  
  .author-bio-col {
    flex: 1;
  }
  
  .author-bio-col h3 {
    font-size: 1.6rem;
    margin-bottom: 4px;
  }
  
  .author-role {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 20px;
  }
  
  .author-bio-col p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 16px;
  }
  
  .author-highlights {
    list-style: none;
    padding: 0;
    margin: 32px 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  
  .author-highlights li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  
  .highlight-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    flex-shrink: 0;
  }
  
  .author-highlights strong {
    display: block;
    color: var(--color-text);
    margin-bottom: 4px;
    font-size: 0.95rem;
  }
  
  .author-highlights span {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  
  .methodology-section p,
  .trust-section p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 16px;
  }
  .methodology-section strong,
  .trust-section strong {
    color: var(--color-text);
  }

  .trust-list {
    list-style: none;
    padding: 0;
    margin: 24px 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .trust-list li {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    padding-left: 24px;
    position: relative;
  }
  .trust-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
  }
  .trust-list li strong {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .author-card {
      flex-direction: column;
      align-items: center;
      padding: 24px;
      gap: 32px;
    }
    .author-avatar-col {
      width: 100%;
    }
    .author-bio-col {
      text-align: center;
    }
    .author-highlights li {
      text-align: left;
    }
  }
</style>
