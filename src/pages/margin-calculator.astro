          <h1>Crypto Margin Calculator</h1>
          <p>Calculate required margin, margin level, free margin, and the exact price that triggers a margin call for your leveraged position.</p>
        </div>
        <div class="calc-scope">
        <MarginCalculator lang={'en'} client:load />
