  .section-container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .calculator-section { padding: 40px 0 60px; }
  .calc-header { margin-bottom: 32px; }
  .calc-header h1 { font-size: 1.75rem; font-weight: 700; margin-bottom: 8px; color: var(--color-text); }
  .calc-header p { color: var(--color-text-secondary); font-size: 0.95rem; max-width: 650px; }
  .seo-content { padding: 60px 0; border-top: 1px solid var(--color-border); }
  .seo-content h2 { font-size: 1.35rem; font-weight: 700; margin-bottom: 16px; color: var(--color-text); }
  .seo-content h2 + h3 { margin-top: 16px; }
  .seo-content h3 { font-size: 1.1rem; font-weight: 600; margin: 24px 0 8px; color: var(--color-text); }
  .seo-content p, .seo-content li { color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 12px; max-width: 780px; }
  .seo-content ol, .seo-content ul { padding-left: 24px; margin-bottom: 16px; }
  .seo-content a { color: var(--color-primary); text-decoration: none; }
  .seo-content a:hover { text-decoration: underline; }
  .seo-content details { margin-bottom: 8px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); overflow: hidden; }
  .seo-content summary { padding: 12px 16px; font-weight: 600; cursor: pointer; color: var(--color-text); background: var(--color-bg-card); }
  .seo-content summary:hover { background: var(--color-bg-card-hover); }
  .seo-content details p { padding: 0 16px 12px; margin-bottom: 0; }
  .seo-content details[open] summary { border-bottom: 1px solid var(--color-border); }
  .formula-block { background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius-sm); padding: 16px 20px; margin: 12px 0 16px; max-width: 780px; }
  .formula-block code { font-size: 0.95rem; color: var(--color-primary); font-weight: 600; }
  .table-responsive { overflow-x: auto; margin: 16px 0 24px; max-width: 780px; }
  .table-responsive table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  .table-responsive th, .table-responsive td { padding: 10px 14px; text-align: left; border-bottom: 1px solid var(--color-border); }
  .table-responsive th { font-weight: 600; color: var(--color-text); background: var(--color-bg-card); }
  .table-responsive td { color: var(--color-text-secondary); }
  .seo-content h2 { margin-top: 40px; }
  .seo-content h2:first-child { margin-top: 0; }
  .site-footer { border-top: 1px solid var(--color-border); padding: 32px 0; }
  .footer-inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .footer-bottom { text-align: center; }
  .footer-bottom p { font-size: 0.8rem; color: var(--color-text-muted); }
</style>

