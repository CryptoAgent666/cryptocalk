---
import Layout from '../layouts/Layout.astro';
import { Calculator } from 'lucide-react';

const title = "404 - Page Not Found";
const description = "The page you are looking for does not exist.";
---

<Layout title={title} description={description} lang="en" noindex={true}>
  <div style="min-height: 80vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 24px;">
    <div style="margin-bottom: 24px; color: var(--color-primary);">
      <Calculator size={64} />
    </div>
    <h1 style="font-size: 3rem; font-weight: 800; margin-bottom: 16px; letter-spacing: -0.02em;">404</h1>
    <h2 style="font-size: 1.5rem; margin-bottom: 24px; color: var(--color-text-secondary);">Page Not Found</h2>
    <p style="margin-bottom: 32px; color: var(--color-text-muted); max-width: 400px; line-height: 1.6;">
      Sorry, we couldn't find the calculator or page you're looking for. It might have been moved or deleted.
    </p>
    <a href="/" style="display: inline-flex; align-items: center; justify-content: center; background: var(--color-primary); color: white; padding: 12px 24px; border-radius: 8px; font-weight: 600; text-decoration: none; transition: opacity 0.2s;">
      Back to Calculators
    </a>
  </div>
</Layout>
