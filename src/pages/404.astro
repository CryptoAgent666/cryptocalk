---
import Layout from '../layouts/Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import {
  ArrowRight,
  Calculator,
  Home,
  Pickaxe,
  PiggyBank,
  Receipt,
  Search,
  TrendingUp,
} from 'lucide-react';

const title = '404 — Page Not Found | CryptoCalk';
const description = 'The page you are looking for does not exist.';
---

<Layout title={title} description={description} lang="en" noindex={true}>
  <main id="main-content" class="notfound-page">
    <section class="notfound-shell">
      <div class="notfound-glow notfound-glow--one" aria-hidden="true"></div>
      <div class="notfound-glow notfound-glow--two" aria-hidden="true"></div>

      <div class="notfound-card">
        <a href="/" class="notfound-brand" aria-label="CryptoCalk home">
          <span class="notfound-brand-icon">
            <Calculator size={18} />
          </span>
          <span class="notfound-brand-text">Crypto<b>Calk</b></span>
        </a>

        <p class="notfound-chip">Error 404</p>
        <h1>This Page Went Missing</h1>
        <p class="notfound-copy">
          The calculator or page you opened may have moved to a new URL. Jump back to the homepage
          or open one of the popular tools below.
        </p>

        <div class="notfound-actions">
          <a href="/" class="notfound-btn notfound-btn--primary">
            <Home size={16} />
            Back to Homepage
            <ArrowRight size={16} />
          </a>
          <a href="/#categories" class="notfound-btn notfound-btn--ghost">
            <Search size={16} />
            Browse Calculators
          </a>
        </div>

        <div class="notfound-divider"></div>

        <ul class="notfound-links" role="list">
          <li>
            <a href="/profit-calculator/">
              <TrendingUp size={15} />
              Profit Calculator
            </a>
          </li>
          <li>
            <a href="/mining-calculator/">
              <Pickaxe size={15} />
              Mining Calculator
            </a>
          </li>
          <li>
            <a href="/dca-calculator/">
              <PiggyBank size={15} />
              DCA Calculator
            </a>
          </li>
          <li>
            <a href="/tax-calculator/">
              <Receipt size={15} />
              Tax Calculator
            </a>
          </li>
        </ul>
      </div>
    </section>
  </main>
  <SiteFooter lang="en" />
</Layout>

<style>
  .notfound-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: clamp(20px, 4vw, 48px);
    background:
      radial-gradient(900px 500px at 10% -10%, rgba(99, 102, 241, 0.2), transparent 55%),
      radial-gradient(700px 450px at 100% 0%, rgba(29, 78, 216, 0.12), transparent 55%),
      var(--color-bg);
  }

  [data-theme='dark'] .notfound-page {
    background:
      radial-gradient(850px 480px at 8% -12%, rgba(99, 102, 241, 0.25), transparent 55%),
      radial-gradient(680px 430px at 100% 0%, rgba(59, 130, 246, 0.17), transparent 55%),
      var(--color-bg);
  }

  .notfound-shell {
    width: min(920px, 100%);
    position: relative;
  }

  .notfound-glow {
    position: absolute;
    filter: blur(60px);
    opacity: 0.55;
    pointer-events: none;
    z-index: 0;
    animation: drift 6s ease-in-out infinite alternate;
  }

  .notfound-glow--one {
    width: 220px;
    height: 220px;
    top: -50px;
    left: -30px;
    background: rgba(99, 102, 241, 0.4);
  }

  .notfound-glow--two {
    width: 200px;
    height: 200px;
    right: -20px;
    bottom: -40px;
    background: rgba(29, 78, 216, 0.35);
    animation-delay: 0.8s;
  }

  .notfound-card {
    position: relative;
    z-index: 1;
    background: linear-gradient(180deg, var(--color-bg-card), color-mix(in srgb, var(--color-bg-card) 92%, #dbeafe 8%));
    border: 1px solid var(--color-border);
    border-radius: 24px;
    box-shadow: var(--shadow-card-hover);
    padding: clamp(24px, 4vw, 44px);
    text-align: center;
  }

  .notfound-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text);
    font-weight: 700;
    margin-bottom: 20px;
  }

  .notfound-brand:hover {
    color: var(--color-text);
  }

  .notfound-brand-icon {
    width: 32px;
    height: 32px;
    border-radius: 10px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .notfound-brand-text b {
    color: var(--color-primary);
  }

  .notfound-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-primary) 25%, var(--color-border));
    color: var(--color-primary);
    background: var(--color-primary-light);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .notfound-card h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 14px;
    color: var(--color-text);
  }

  .notfound-copy {
    max-width: 60ch;
    margin: 0 auto 28px;
    color: var(--color-text-secondary);
    font-size: clamp(0.95rem, 1.7vw, 1.05rem);
    line-height: 1.65;
  }

  .notfound-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .notfound-btn {
    min-height: 46px;
    padding: 0 18px;
    border-radius: 12px;
    border: 1px solid transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-weight: 700;
    font-size: 0.92rem;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background-color 0.18s ease;
  }

  .notfound-btn:hover {
    transform: translateY(-1px);
  }

  .notfound-btn--primary {
    color: #fff;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-hover));
    box-shadow: 0 10px 24px rgba(79, 70, 229, 0.25);
  }

  .notfound-btn--primary:hover {
    color: #fff;
  }

  .notfound-btn--ghost {
    color: var(--color-text);
    border-color: var(--color-border);
    background: var(--color-bg-card);
  }

  .notfound-btn--ghost:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
    background: var(--color-bg-card-hover);
  }

  .notfound-divider {
    height: 1px;
    background: var(--color-border);
    margin: 26px 0 20px;
  }

  .notfound-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .notfound-links a {
    min-height: 44px;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 10px 12px;
    background: var(--color-bg-card);
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    justify-content: center;
    transition: border-color 0.18s ease, color 0.18s ease, background-color 0.18s ease;
  }

  .notfound-links a:hover {
    color: var(--color-text);
    border-color: var(--color-primary);
    background: var(--color-bg-card-hover);
  }

  @media (max-width: 720px) {
    .notfound-card {
      border-radius: 18px;
      padding: 22px 16px 18px;
    }

    .notfound-links {
      grid-template-columns: 1fr;
    }

    .notfound-actions {
      flex-direction: column;
    }

    .notfound-btn {
      width: 100%;
    }
  }

  @keyframes drift {
    from {
      transform: translateY(-6px) scale(1);
    }
    to {
      transform: translateY(8px) scale(1.05);
    }
  }
</style>
