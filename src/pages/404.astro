---
import Layout from '../layouts/Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import {
  ArrowRight,
  Calculator,
  Home,
  Pickaxe,
  PiggyBank,
  Receipt,
  Search,
  TrendingUp,
} from 'lucide-react';

const title = '404 — Page Not Found — CryptoCalk';
const description = 'The page you are looking for does not exist.';
---

<Layout title={title} description={description} lang="en" noindex={true}>
  <main id="main-content" class="notfound-page">
    <section class="notfound-shell">
      <div class="notfound-glow notfound-glow--one" aria-hidden="true"></div>
      <div class="notfound-glow notfound-glow--two" aria-hidden="true"></div>

      <div class="notfound-card">
        <a href="/" class="notfound-brand" aria-label="CryptoCalk home">
          <span class="notfound-brand-icon">
            <Calculator size={18} />
          </span>
          <span class="notfound-brand-text">Crypto<b>Calk</b></span>
        </a>

        <p class="notfound-chip">Error 404</p>
        <h1 data-i18n="heading">This Page Went Missing</h1>
        <p class="notfound-copy" data-i18n="copy">
          The calculator or page you opened may have moved to a new URL. Jump back to the homepage
          or open one of the popular tools below.
        </p>

        <div class="notfound-actions">
          <a href="/" class="notfound-btn notfound-btn--primary" data-i18n-link="home">
            <Home size={16} />
            <span data-i18n="backHome">Back to Homepage</span>
            <ArrowRight size={16} />
          </a>
          <a href="/#categories" class="notfound-btn notfound-btn--ghost" data-i18n-link="browse">
            <Search size={16} />
            <span data-i18n="browse">Browse Calculators</span>
          </a>
        </div>

        <div class="notfound-divider"></div>

        <ul class="notfound-links" role="list">
          <li>
            <a href="/profit-calculator/" data-i18n-link="profit">
              <TrendingUp size={15} />
              <span data-i18n="profit">Profit Calculator</span>
            </a>
          </li>
          <li>
            <a href="/mining-calculator/" data-i18n-link="mining">
              <Pickaxe size={15} />
              <span data-i18n="mining">Mining Calculator</span>
            </a>
          </li>
          <li>
            <a href="/dca-calculator/" data-i18n-link="dca">
              <PiggyBank size={15} />
              <span data-i18n="dca">DCA Calculator</span>
            </a>
          </li>
          <li>
            <a href="/tax-calculator/" data-i18n-link="tax">
              <Receipt size={15} />
              <span data-i18n="tax">Tax Calculator</span>
            </a>
          </li>
        </ul>
      </div>
    </section>
  </main>
  <SiteFooter lang="en" />
</Layout>

<script>
  const i18n: Record<string, Record<string, string>> = {
    es: {
      heading: 'Esta Página No Existe',
      copy: 'La calculadora o página que buscas pudo haberse movido a una nueva URL. Vuelve al inicio o abre una de las herramientas populares.',
      backHome: 'Volver al Inicio',
      browse: 'Explorar Calculadoras',
      profit: 'Calculadora de Ganancias',
      mining: 'Calculadora de Minería',
      dca: 'Calculadora DCA',
      tax: 'Calculadora de Impuestos',
    },
    pt: {
      heading: 'Esta Página Não Existe',
      copy: 'A calculadora ou página que você abriu pode ter sido movida. Volte à página inicial ou abra uma das ferramentas populares.',
      backHome: 'Voltar ao Início',
      browse: 'Explorar Calculadoras',
      profit: 'Calculadora de Lucro',
      mining: 'Calculadora de Mineração',
      dca: 'Calculadora DCA',
      tax: 'Calculadora de Impostos',
    },
    tr: {
      heading: 'Bu Sayfa Bulunamadı',
      copy: 'Açmak istediğiniz hesap makinesi veya sayfa taşınmış olabilir. Ana sayfaya dönün veya popüler araçlardan birini açın.',
      backHome: 'Ana Sayfaya Dön',
      browse: 'Hesap Makinelerini Keşfet',
      profit: 'Kâr Hesaplayıcı',
      mining: 'Madencilik Hesaplayıcı',
      dca: 'DCA Hesaplayıcı',
      tax: 'Vergi Hesaplayıcı',
    },
    hi: {
      heading: 'यह पेज नहीं मिला',
      copy: 'आपने जो कैलकुलेटर या पेज खोला वह एक नए URL पर स्थानांतरित हो गया होगा। होमपेज पर वापस जाएं या नीचे लोकप्रिय टूल में से एक खोलें।',
      backHome: 'होमपेज पर वापस',
      browse: 'कैलकुलेटर देखें',
      profit: 'प्रॉफिट कैलकुलेटर',
      mining: 'माइनिंग कैलकुलेटर',
      dca: 'DCA कैलकुलेटर',
      tax: 'टैक्स कैलकुलेटर',
    },
    ru: {
      heading: 'Страница не найдена',
      copy: 'Калькулятор или страница могли переместиться на новый URL. Вернитесь на главную или откройте один из популярных инструментов.',
      backHome: 'На главную',
      browse: 'Все калькуляторы',
      profit: 'Калькулятор прибыли',
      mining: 'Калькулятор майнинга',
      dca: 'DCA калькулятор',
      tax: 'Налоговый калькулятор',
    },
  };

  const langPrefixes = ['es', 'pt', 'tr', 'hi', 'ru'];
  const path = window.location.pathname;
  const match = path.match(/^\/(es|pt|tr|hi|ru)\//);
  const lang = match ? match[1] : null;

  if (lang && i18n[lang]) {
    const t = i18n[lang];
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n!;
      if (t[key]) el.textContent = t[key];
    });
    // Update links to include language prefix
    document.querySelectorAll<HTMLAnchorElement>('[data-i18n-link]').forEach(a => {
      const href = a.getAttribute('href');
      if (href && href.startsWith('/') && !href.startsWith(`/${lang}/`)) {
        a.setAttribute('href', `/${lang}${href}`);
      }
    });
    // Update html lang attribute
    document.documentElement.lang = lang;
  }
</script>

<style>
  .notfound-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: clamp(20px, 4vw, 48px);
    background:
      radial-gradient(900px 500px at 10% -10%, rgba(8, 145, 178, 0.2), transparent 55%),
      radial-gradient(700px 450px at 100% 0%, rgba(29, 78, 216, 0.12), transparent 55%),
      var(--color-bg);
  }

  [data-theme='dark'] .notfound-page {
    background:
      radial-gradient(850px 480px at 8% -12%, rgba(8, 145, 178, 0.25), transparent 55%),
      radial-gradient(680px 430px at 100% 0%, rgba(59, 130, 246, 0.17), transparent 55%),
      var(--color-bg);
  }

  .notfound-shell {
    width: min(920px, 100%);
    position: relative;
  }

  .notfound-glow {
    position: absolute;
    filter: blur(60px);
    opacity: 0.55;
    pointer-events: none;
    z-index: 0;
    animation: drift 6s ease-in-out infinite alternate;
  }

  .notfound-glow--one {
    width: 220px;
    height: 220px;
    top: -50px;
    left: -30px;
    background: rgba(8, 145, 178, 0.4);
  }

  .notfound-glow--two {
    width: 200px;
    height: 200px;
    right: -20px;
    bottom: -40px;
    background: rgba(29, 78, 216, 0.35);
    animation-delay: 0.8s;
  }

  .notfound-card {
    position: relative;
    z-index: 1;
    background: linear-gradient(180deg, var(--color-bg-card), color-mix(in srgb, var(--color-bg-card) 92%, #dbeafe 8%));
    border: 1px solid var(--color-border);
    border-radius: 24px;
    box-shadow: var(--shadow-card-hover);
    padding: clamp(24px, 4vw, 44px);
    text-align: center;
  }

  .notfound-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text);
    font-weight: 700;
    margin-bottom: 20px;
  }

  .notfound-brand:hover {
    color: var(--color-text);
  }

  .notfound-brand-icon {
    width: 32px;
    height: 32px;
    border-radius: 10px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .notfound-brand-text b {
    color: var(--color-primary);
  }

  .notfound-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-primary) 25%, var(--color-border));
    color: var(--color-primary);
    background: var(--color-primary-light);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .notfound-card h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 14px;
    color: var(--color-text);
  }

  .notfound-copy {
    max-width: 60ch;
    margin: 0 auto 28px;
    color: var(--color-text-secondary);
    font-size: clamp(0.95rem, 1.7vw, 1.05rem);
    line-height: 1.65;
  }

  .notfound-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .notfound-btn {
    min-height: 46px;
    padding: 0 18px;
    border-radius: 12px;
    border: 1px solid transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-weight: 700;
    font-size: 0.92rem;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background-color 0.18s ease;
  }

  .notfound-btn:hover {
    transform: translateY(-1px);
  }

  .notfound-btn--primary {
    color: #fff;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-hover));
    box-shadow: 0 10px 24px rgba(79, 70, 229, 0.25);
  }

  .notfound-btn--primary:hover {
    color: #fff;
  }

  .notfound-btn--ghost {
    color: var(--color-text);
    border-color: var(--color-border);
    background: var(--color-bg-card);
  }

  .notfound-btn--ghost:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
    background: var(--color-bg-card-hover);
  }

  .notfound-divider {
    height: 1px;
    background: var(--color-border);
    margin: 26px 0 20px;
  }

  .notfound-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .notfound-links a {
    min-height: 44px;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 10px 12px;
    background: var(--color-bg-card);
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    justify-content: center;
    transition: border-color 0.18s ease, color 0.18s ease, background-color 0.18s ease;
  }

  .notfound-links a:hover {
    color: var(--color-text);
    border-color: var(--color-primary);
    background: var(--color-bg-card-hover);
  }

  @media (max-width: 720px) {
    .notfound-card {
      border-radius: 18px;
      padding: 22px 16px 18px;
    }

    .notfound-links {
      grid-template-columns: 1fr;
    }

    .notfound-actions {
      flex-direction: column;
    }

    .notfound-btn {
      width: 100%;
    }
  }

  @keyframes drift {
    from {
      transform: translateY(-6px) scale(1);
    }
    to {
      transform: translateY(8px) scale(1.05);
    }
  }
</style>
