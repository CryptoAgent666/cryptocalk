        <ThemeToggle client:idle />
      </nav>
    </div>
  </header>

  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="section-container">
        <a href="/">Home</a>
        <ChevronRight size={12} />
        <a href="/calculators/trading-tools/">Trading Tools</a>
        <ChevronRight size={12} />
        <a href="/leverage-calculator/" aria-current="page">Leverage Calculator</a>
