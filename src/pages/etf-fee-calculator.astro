---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.tsx';
import LanguageSwitcher from '../components/LanguageSwitcher.tsx';
import EtfFeeCalculator from '../components/EtfFeeCalculator.tsx';
import { Calculator, ChevronRight, ArrowLeft } from 'lucide-react';
import SiteFooter from '../components/SiteFooter.astro';
import ShareCalculator from '../components/ShareCalculator.astro';
import '../styles/calculator-page.css';

const buildDate = new Date().toISOString().split('T')[0];
---

<Layout
  title="Bitcoin ETF Fee Calculator"
  description="Compare expense ratios of IBIT, FBTC, GBTC, ARKB, BITB, and direct BTC. See how fees compound over 1–30 years."
  lang="en"
  pageType="calculator"
>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">
        <Calculator size={24} />
        <span class="logo-text">Crypto<b>Calk</b></span>
      </a>
      <nav class="header-actions" aria-label="Main navigation">
        <a href="/" class="header-link">
          <ArrowLeft size={14} />
          All Calculators
        </a>
        <LanguageSwitcher client:idle currentLang="en" currentPath="/etf-fee-calculator" />
        <ThemeToggle client:idle />
      </nav>
    </div>
  </header>

  <main id="main-content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="section-container">
        <a href="/">Home</a>
        <ChevronRight size={12} />
        <a href="/calculators/gas-fees/">Gas & Fees</a>
        <ChevronRight size={12} />
        <a href="/etf-fee-calculator/" aria-current="page">ETF Fee Calculator</a>
      </div>
    </nav>

    <section class="calculator-section">
      <div class="section-container">
        <div class="calc-header">
          <h1>Bitcoin ETF Fee Calculator</h1>
          <p>Compare expense ratios of IBIT, FBTC, GBTC, ARKB, BITB, and direct BTC. See how fees compound over 1–30 years.</p>
          <div class="calc-byline">
            <a href="/about/" class="byline-link">
              <span class="byline-by">By</span>
              <span class="byline-name">Konstantin Iakovlev</span>
            </a>
            <span class="byline-sep">·</span>
            <span class="byline-date">Updated {buildDate}</span>
          </div>
        </div>

        <div class="calc-scope">
          <EtfFeeCalculator lang={'en'} client:load />
          <ShareCalculator lang="en" />
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>
