---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.tsx';
import LanguageSwitcher from '../components/LanguageSwitcher.tsx';
import { getHomepageCategories } from '../data/category-hubs';
import {
  Calculator,
  TrendingUp,
  Pickaxe,
  PiggyBank,
  Receipt,
  ArrowLeftRight,
  BarChart3,
  Zap,
  Search,
  ChevronRight,
  Sparkles,
  Globe,
} from 'lucide-react';

const categories = getHomepageCategories('en');

const popularCalculators = [
  { name: 'Crypto Profit Calculator', href: '/profit-calculator/', tag: 'Popular', tagType: 'popular' },
  { name: 'Crypto Converter', href: '/converter/', tag: 'Popular', tagType: 'popular' },
  { name: 'Bitcoin Mining Calculator', href: '/mining-calculator/', tag: 'Popular', tagType: 'popular' },
  { name: 'DCA Calculator', href: '/dca-calculator/', tag: 'Popular', tagType: 'popular' },
  { name: 'Crypto Tax Calculator', href: '/tax-calculator/', tag: 'Popular', tagType: 'popular' },
  { name: 'Position Size Calculator', href: '/position-size-calculator/', tag: 'Popular', tagType: 'popular' },
  { name: 'Liquidation Calculator', href: '/liquidation-calculator/', tag: 'Popular', tagType: 'popular' },
  { name: 'Staking Rewards Calculator', href: '/staking-calculator/', tag: 'Trending', tagType: 'trending' },
  { name: 'Gas Fee Calculator', href: '/gas-calculator/', tag: 'Trending', tagType: 'trending' },
  { name: 'Portfolio VaR Calculator', href: '/var-calculator/', tag: 'Trending', tagType: 'trending' },
  { name: 'Break-Even Calculator', href: '/break-even-calculator/', tag: 'Trending', tagType: 'trending' },
  { name: 'What If Calculator', href: '/what-if/', tag: 'Trending', tagType: 'trending' },
  { name: 'If I Had Bought…', href: '/if-i-had-bought/', tag: 'New', tagType: 'new' },
  { name: 'Pizza Day Calculator', href: '/pizza-day-calculator/', tag: 'New', tagType: 'new' },
  { name: 'Crypto Millionaire Calculator', href: '/millionaire-calculator/', tag: 'New', tagType: 'new' },
];

const footerCoreLinks = [
  { name: 'Profit Calculator', href: '/profit-calculator/' },
  { name: 'Crypto Converter', href: '/converter/' },
  { name: 'Mining Calculator', href: '/mining-calculator/' },
  { name: 'DCA Calculator', href: '/dca-calculator/' },
  { name: 'Tax Calculator', href: '/tax-calculator/' },
  { name: 'Position Size Calculator', href: '/position-size-calculator/' },
];

const footerExploreLinks = [
  { name: 'Staking Rewards', href: '/staking-calculator/' },
  { name: 'Gas Fee Calculator', href: '/gas-calculator/' },
  { name: 'Portfolio Calculator', href: '/portfolio-calculator/' },
  { name: 'What If Calculator', href: '/what-if/' },
  { name: 'Break-Even Calculator', href: '/break-even-calculator/' },
  { name: 'All Categories', href: '/#categories' },
];

const siteUrl = 'https://cryptocalk.com';
const homepageUrl = `${siteUrl}/`;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  name: 'CryptoCalk',
  url: homepageUrl,
  description:
    'Free online cryptocurrency calculators: profit & loss, mining profitability, DCA simulator, tax estimator, staking rewards, and 93 more tools.',
  inLanguage: 'en',
  publisher: { '@type': 'Organization', '@id': `${siteUrl}/#organization` },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${homepageUrl}?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: 'CryptoCalk',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/logo-200x200.png`,
    width: 200,
    height: 200,
  },
  email: 'support@cryptocalk.com',
  sameAs: [
    'https://x.com/yakovlevka3',
    'https://github.com/CryptoAgent666/cryptocalk',
    'https://www.linkedin.com/in/konstantin-iakovlev/',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'support@cryptocalk.com',
    contactType: 'customer support',
    availableLanguage: ['en', 'es', 'pt', 'tr', 'hi', 'ru'],
  },
  founder: {
    '@type': 'Person',
    '@id': `${siteUrl}/about/#founder`,
    name: 'Konstantin Iakovlev',
  },
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Popular Crypto Calculators',
  numberOfItems: popularCalculators.length,
  itemListElement: popularCalculators.map((calc, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: calc.name,
    url: `${siteUrl}${calc.href}`,
  })),
};

const buildDate = new Date().toISOString().split('T')[0];

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${homepageUrl}#app`,
  name: 'CryptoCalk',
  url: homepageUrl,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  description: 'Free online cryptocurrency calculators: profit & loss, mining profitability, DCA simulator, tax estimator, staking rewards, and 93 more tools.',
  inLanguage: 'en',
  datePublished: '2025-11-01',
  dateModified: buildDate,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: {
    '@type': 'Person',
    '@id': `${siteUrl}/about/#founder`,
    name: 'Konstantin Iakovlev',
    url: `${siteUrl}/about/`,
  },
};

const homepageFaqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is CryptoCalk free to use?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, completely free. All 93 calculators work without signup, payment, or ads. The site is open-source and the codebase is publicly available on GitHub.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are my calculations private?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Every calculation runs in your browser using client-side JavaScript. No trade data, portfolio values, or personal information is sent to our servers.',
      },
    },
    {
      '@type': 'Question',
      name: 'How accurate are the calculators?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Our calculators use standard financial formulas documented on the methodology page. Market data like BTC and ETH prices is pulled from CoinGecko in real time; other inputs use up-to-date benchmarks. Results are estimates — always verify with your exchange.',
      },
    },
    {
      '@type': 'Question',
      name: 'What cryptocurrencies are supported?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The Profit Calculator and Converter support 500+ cryptocurrencies via CoinGecko API. Specialized calculators support Bitcoin, Ethereum, Solana, and major L2s like Arbitrum and Polygon.',
      },
    },
    {
      '@type': 'Question',
      name: 'Who built CryptoCalk?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'CryptoCalk was created by Konstantin Iakovlev, a developer with 10+ years in finance and technology, active in cryptocurrency since 2017.',
      },
    },
  ],
};

const homepageSchemas = [websiteSchema, organizationSchema, itemListSchema, softwareAppSchema, homepageFaqSchema];
---

<Layout
  title="CryptoCalk — 93 Free Crypto Calculators"
  description="Free crypto calculators: profit & loss, mining, DCA, tax, staking, and 93 more tools. Fast, accurate, no signup required."
  lang="en"
>
  <!-- Header -->
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">
        <Calculator size={24} />
        <span class="logo-text">Crypto<b>Calk</b></span>
      </a>

      <div class="header-search" role="search">
        <label class="sr-only" for="search-input">Search calculators</label>
        <Search size={16} />
        <input type="search" placeholder="Search calculators..." id="search-input" autocomplete="off" spellcheck="false" />
        <button type="button" id="search-clear-btn" class="search-clear-btn" aria-label="Clear search" hidden>
          ×
        </button>
      </div>

      <nav class="header-actions" aria-label="Main navigation">
        <a href="#categories" class="header-link">Calculators</a>
        <LanguageSwitcher client:idle currentLang="en" currentPath="/" />
        <ThemeToggle client:idle />
      </nav>
    </div>
  </header>

  <main id="main-content">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-badge">
          <Globe size={14} />
          <span>93 Free Calculators • No Signup Required</span>
        </div>
        <h1>
          93 Free <span class="hero-accent">Crypto</span><br />
          Calculators
        </h1>
        <p class="hero-subtitle">
          Profit & loss, mining profitability, DCA simulator, tax estimator, staking rewards, and more — all in one place. Lightning fast, privacy-first.
        </p>
        <div class="hero-actions">
          <a href="/profit-calculator/" class="btn-primary">
            Start Calculating
            <ChevronRight size={16} />
          </a>
          <a href="#categories" class="btn-secondary">
            Browse All Tools
          </a>
        </div>

        <!-- Trusted by users worldwide -->
        <p class="hero-trust">Free, open tools — no signup, no tracking, privacy-first.</p>
      </div>
    </section>

    <!-- Popular Calculators (Horizontal Scroll) -->
    <section class="popular-section">
      <div class="section-container">
        <h2 class="section-title"><span aria-hidden="true">🔥</span> Popular Calculators</h2>
        <div class="popular-grid">
          {popularCalculators.map((calc) => (
            <a
              href={calc.href}
              class="popular-card card-hover"
              data-search-item
              data-search-text={`${calc.name} ${calc.tag ?? ''}`}
            >
              <div class="popular-card-content">
                <span class="popular-name">{calc.name}</span>
                {calc.tag && <span class="popular-tag" data-tag={calc.tagType}>{calc.tag}</span>}
              </div>
              <ChevronRight size={16} class="popular-arrow" />
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="search-feedback">
      <div class="section-container">
        <p id="search-status" class="search-status" aria-live="polite" hidden></p>
        <div id="search-empty" class="search-empty" hidden>
          <h3>No calculators found</h3>
          <p>Try a broader keyword or clear search to browse all tools.</p>
          <button type="button" id="search-empty-reset" class="search-reset-btn">Clear Search</button>
        </div>
      </div>
    </section>

    <!-- Categories Bento Grid -->
    <section class="categories-section" id="categories">
      <div class="section-container">
        <h2 class="section-title">All Calculator Categories</h2>
        <p class="section-subtitle">Choose a category to find the right tool for your needs</p>

        <div class="bento-grid">
          {categories.map((cat) => (
            <article
              class:list={['bento-card', 'card-hover', { 'bento-featured': cat.featured }]}
              style={`--card-accent: ${cat.color}`}
              data-search-item
              data-search-text={`${cat.title} ${cat.description} ${cat.calculators.map((tool) => tool.name).join(' ')}`}
            >
              <div class="bento-top">
                <div class="bento-icon" style={`background-color: ${cat.color}15; color: ${cat.color}`}>
                  {cat.icon === 'TrendingUp' && <TrendingUp size={24} />}
                  {cat.icon === 'ArrowLeftRight' && <ArrowLeftRight size={24} />}
                  {cat.icon === 'Pickaxe' && <Pickaxe size={24} />}
                  {cat.icon === 'Sparkles' && <Sparkles size={24} />}
                  {cat.icon === 'Receipt' && <Receipt size={24} />}
                  {cat.icon === 'PiggyBank' && <PiggyBank size={24} />}
                  {cat.icon === 'BarChart3' && <BarChart3 size={24} />}
                  {cat.icon === 'Zap' && <Zap size={24} />}
                </div>
                <a href={cat.href} class="bento-title-link">
                  <h3>{cat.title}</h3>
                  <ChevronRight size={18} />
                </a>
              </div>
              <p class="bento-description">{cat.description}</p>
              <span class="bento-count">{cat.count} calculators</span>
              <ul class="bento-list">
                {cat.calculators.slice(0, 6).map((tool) => (
                  <li>
                    <a href={tool.href}>{tool.name}</a>
                  </li>
                ))}
              </ul>
              <a href={cat.href} class="bento-view-link">
                View category
                <ChevronRight size={16} />
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="features-section">
      <div class="section-container">
        <h2 class="section-title">Why CryptoCalk?</h2>
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon feature-icon--green" aria-hidden="true">⚡</div>
            <h3>Blazing Fast</h3>
            <p>Static HTML + minimal JS. Pages load in under 1 second, even on 3G.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon feature-icon--cyan" aria-hidden="true">🔒</div>
            <h3>Privacy First</h3>
            <p>All calculations run in your browser. No data leaves your device. No tracking.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon feature-icon--amber" aria-hidden="true">🌍</div>
            <h3>Multilingual</h3>
            <p>Available in 6 languages: English, Spanish, Portuguese, Turkish, Hindi, and Russian.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon feature-icon--pink" aria-hidden="true">📱</div>
            <h3>Mobile Ready</h3>
            <p>Responsive design with touch-optimized controls. Use anywhere, anytime.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- What is CryptoCalk + FAQ -->
    <section class="about-section">
      <div class="section-container">
        <h2 class="section-title">What Is CryptoCalk?</h2>
        <div class="about-prose">
          <p>CryptoCalk is a free, open-source suite of <strong>93 cryptocurrency calculators</strong> available in <strong>6 languages</strong> (English, Spanish, Portuguese, Turkish, Hindi, and Russian) — totaling over 1,100 pages of tools and educational content. Every calculation runs entirely in your browser: no data is sent to our servers and no account is required.</p>
          <p>Our tools cover the full spectrum of crypto decision-making: <a href="/profit-calculator/">profit and loss analysis</a>, <a href="/mining-calculator/">mining profitability</a>, <a href="/dca-calculator/">dollar-cost averaging simulation</a>, <a href="/tax-calculator/">tax estimation for 17 countries</a>, <a href="/staking-calculator/">staking rewards projection</a>, risk-adjusted performance metrics (Sharpe, Sortino, VaR), and DeFi yield comparison. Each calculator includes detailed methodology, worked examples, and search-targeted FAQ.</p>
          <p>Built with <a href="/methodology/">documented formulas</a> and real-time market data from CoinGecko, CryptoCalk is designed for traders, investors, and researchers who want reliable numbers without signup walls, premium tiers, or tracking cookies.</p>
        </div>

        <h2 class="section-title" style="margin-top: 48px;">Frequently Asked Questions</h2>
        <div class="home-faq">
          <details class="faq-item">
            <summary>Is CryptoCalk free to use?</summary>
            <p>Yes, completely free. All 93 calculators work without signup, payment, or ads. The site is open-source and the codebase is publicly available on GitHub.</p>
          </details>
          <details class="faq-item">
            <summary>Are my calculations private?</summary>
            <p>Yes. Every calculation runs in your browser using client-side JavaScript. No trade data, portfolio values, or personal information is sent to our servers. We use Google Analytics for anonymous page view statistics only.</p>
          </details>
          <details class="faq-item">
            <summary>How accurate are the calculators?</summary>
            <p>Our calculators use standard financial formulas documented on the <a href="/methodology/">methodology page</a>. Market data like BTC and ETH prices is pulled from CoinGecko in real time; other inputs (difficulty, gas prices) use up-to-date benchmarks you can adjust. Results are estimates — always verify with your exchange's actual figures before making financial decisions.</p>
          </details>
          <details class="faq-item">
            <summary>What cryptocurrencies are supported?</summary>
            <p>The Profit Calculator and Converter support 500+ cryptocurrencies via CoinGecko's API. Specialized calculators (mining, staking, gas) support specific networks including Bitcoin, Ethereum, Solana, and major L2s.</p>
          </details>
          <details class="faq-item">
            <summary>Who built CryptoCalk?</summary>
            <p>CryptoCalk was created by <a href="/about/">Konstantin Iakovlev</a>, a developer with 10+ years in finance and technology, active in cryptocurrency since 2017.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- Creator credibility -->
    <section class="creator-section">
      <div class="section-container">
        <div class="creator-card">
          <div class="creator-info">
            <span class="creator-label">Built by</span>
            <strong class="creator-name">Konstantin Iakovlev</strong>
            <span class="creator-meta">10+ years in finance & crypto</span>
          </div>
          <a href="/about/" class="creator-link">About the creator <ChevronRight size={14} /></a>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="logo-text">Crypto<b>Calk</b></span>
        <p>Free cryptocurrency calculators for everyone.</p>
        <a
          href="https://play.google.com/store/apps/details?id=com.cryptocalk.calculator"
          class="gplay-badge"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Get CryptoCalk on Google Play"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" aria-hidden="true" class="gplay-icon">
            <path d="M46.3 2.1c-3.5 2.1-8.3 7.3-8.3 20.5v466.8c0 13.2 4.8 18.4 8.3 20.5L271 256z" fill="#4285F4"/>
            <path d="M271 256L46.3 509.9c3.1 1.7 7.2 2.3 11.9-.4l284.6-163.8z" fill="#EA4335"/>
            <path d="M271 256l71.8-89.7L58.2 2.5c-4.7-2.7-8.8-2.1-11.9-.4z" fill="#34A853"/>
            <path d="M342.8 345.7L474 270.3c19.5-11.2 19.5-29.4 0-40.6l-131.2-75.4L271 256z" fill="#FBBC04"/>
          </svg>
          <span class="gplay-text">
            <span class="gplay-sub">GET IT ON</span>
            <span class="gplay-main">Google Play</span>
          </span>
        </a>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <h4>Core Calculators</h4>
          {footerCoreLinks.map((link) => (
            <a href={link.href}>{link.name}</a>
          ))}
        </div>
        <div class="footer-col">
          <h4>Explore</h4>
          {footerExploreLinks.map((link) => (
            <a href={link.href}>{link.name}</a>
          ))}
        </div>
        <div class="footer-col">
          <h4>Trust & Legal</h4>
          <a href="/about/">About Us</a>
          <a href="/contact/">Contact Us</a>
          <a href="/privacy/">Privacy Policy</a>
          <a href="/terms/">Terms of Service</a>
          <a href="/editorial-policy/">Editorial Policy</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 CryptoCalk. All rights reserved. For informational purposes only — not financial advice.</p>
      </div>
    </div>
  </footer>

  <script is:inline>
    (() => {
      const input = document.getElementById('search-input');
      const clearButton = document.getElementById('search-clear-btn');
      const status = document.getElementById('search-status');
      const emptyState = document.getElementById('search-empty');
      const emptyReset = document.getElementById('search-empty-reset');
      if (!input) return;

      const items = Array.from(document.querySelectorAll('[data-search-item]'));
      const normalize = (value) => String(value || '').toLowerCase().trim();
      const applyFilter = (query) => {
        let visibleCount = 0;
        let toolCount = 0;
        items.forEach((item) => {
          const text = normalize(item.getAttribute('data-search-text'));
          const visible = !query || text.includes(query);
          item.hidden = !visible;
          if (visible) {
            visibleCount += 1;
            const tools = item.querySelectorAll('.bento-list li');
            if (tools.length > 0) {
              toolCount += parseInt(item.querySelector('.bento-count')?.textContent) || tools.length;
            } else {
              toolCount += 1;
            }
          }
        });
        if (clearButton) clearButton.hidden = !query;
        if (status) {
          status.hidden = !query;
          if (query) {
            const label = toolCount === 1 ? 'calculator' : 'calculators';
            status.textContent = `${toolCount} ${label} found for "${query}"`;
          }
        }
        if (emptyState) {
          emptyState.hidden = !(query && visibleCount === 0);
        }
      };

      const syncQueryParam = (query) => {
        const nextUrl = new URL(window.location.href);
        if (query) {
          nextUrl.searchParams.set('q', query);
        } else {
          nextUrl.searchParams.delete('q');
        }
        window.history.replaceState({}, '', `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`);
      };

      const initialQuery = normalize(new URL(window.location.href).searchParams.get('q'));
      if (initialQuery) {
        input.value = initialQuery;
        applyFilter(initialQuery);
      }

      const clearSearch = () => {
        input.value = '';
        applyFilter('');
        syncQueryParam('');
        input.focus();
      };

      input.addEventListener('input', (event) => {
        const query = normalize(event.target.value);
        applyFilter(query);
        syncQueryParam(query);
      });

      input.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && input.value) {
          clearSearch();
        }
      });

      if (clearButton) {
        clearButton.addEventListener('click', clearSearch);
      }

      if (emptyReset) {
        emptyReset.addEventListener('click', clearSearch);
      }
    })();
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(homepageSchemas)} />
</Layout>

<style>
  /* ===== Header ===== */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg-header);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-header);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text);
    font-size: 1.25rem;
    font-weight: 600;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo:hover { color: var(--color-text); }

  .logo-text {
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .logo-text b {
    font-weight: 800;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .header-search {
    flex: 1;
    max-width: 400px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    transition: border-color 0.2s ease;
  }

  .header-search:focus-within {
    border-color: var(--color-primary);
  }

  .header-search input {
    flex: 1;
