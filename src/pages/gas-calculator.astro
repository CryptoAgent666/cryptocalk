---
import LocalizedCalculatorPage from '../components/LocalizedCalculatorPage.astro';
import GasFeeCalculator from '../components/GasFeeCalculator.tsx';
---

<LocalizedCalculatorPage
  lang="en"
  slug="gas-calculator"
  title="Crypto Gas Fee Calculator — ETH, BSC, Polygon, Arbitrum"
  description="Free gas fee calculator for Ethereum, BSC, Polygon, Arbitrum, Base, Optimism and all major EVM networks. Estimate swap, transfer, NFT mint, and DeFi costs in Gwei and USD before you confirm a transaction."
>
  <GasFeeCalculator slot="calculator" lang={'en'} client:load />
</LocalizedCalculatorPage>

<style>
  .calc-wrapper { width: 100%; }
</style>
