---
import LocalizedCalculatorPage from '../components/LocalizedCalculatorPage.astro';
import DifficultyEstimatorCalculator from '../components/DifficultyEstimatorCalculator.tsx';
---

<LocalizedCalculatorPage
  lang="en"
  slug="difficulty-calculator"
  title="Bitcoin Difficulty Estimator — Next Adjustment Calculator"
  description="Free Bitcoin mining difficulty estimator. Predict the next difficulty adjustment from current block intervals and see exactly how it impacts your mining revenue, breakeven hashrate, and ASIC profitability."
>
  <DifficultyEstimatorCalculator slot="calculator" lang={'en'} client:load />
</LocalizedCalculatorPage>

<style>
  .calc-wrapper { width: 100%; }
</style>
