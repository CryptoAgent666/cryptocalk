<style is:global>
  /* ===== Calculator Component Styles ===== */
  .calc-wrapper {
    width: 100%;
  }
  .calc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }

  /* Input Panel */
  .calc-input-panel {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    position: relative;
  }

  .input-group label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: 6px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .label-hint {
    font-size: 0.7rem;
    color: var(--color-accent-green);
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
  }

  .input-with-prefix {
    display: flex;
    align-items: center;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .input-with-prefix:focus-within {
    border-color: var(--color-primary);
  }

  .input-prefix {
    padding: 10px 0 10px 14px;
    color: var(--color-text-muted);
    font-weight: 600;
    font-size: 0.9rem;
    user-select: none;
  }

  .input-with-prefix input,
  .input-group > input {
    width: 100%;
    border: none;
    background: none;
    outline: none;
    padding: 10px 14px;
    font-size: 0.95rem;
    color: var(--color-text);
    font-family: inherit;
  }

  .input-group > input {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: border-color 0.2s ease;
  }

  .input-group > input:focus {
    border-color: var(--color-primary);
    outline: none;
  }

  .input-group.compact {
    flex: 1;
  }

  .input-group.compact input {
    padding: 8px 12px;
    font-size: 0.85rem;
  }

  /* Coin search */
  .coin-search-wrapper {
    position: relative;
  }

  .coin-search-wrapper input {
    width: 100%;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    font-size: 0.95rem;
    color: var(--color-text);
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .coin-search-wrapper input:focus {
    border-color: var(--color-primary);
  }

  .coin-clear {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    border: none;
    background: var(--color-bg-card-hover);
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    display: flex;
    line-height: 1;
  }

  .suggestions-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-card-hover);
    z-index: 50;
    overflow: hidden;
    margin-top: 4px;
  }

  .suggestion-item {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 10px 14px;
    border: none;
    background: none;
    color: var(--color-text);
    cursor: pointer;
    font-size: 0.9rem;
    font-family: inherit;
    text-align: left;
    transition: background-color 0.1s ease;
  }

  .suggestion-item:hover {
    background-color: var(--color-bg-card-hover);
  }

  .suggestion-item img {
    border-radius: 50%;
  }

  .suggestion-name {
    flex: 1;
    font-weight: 500;
  }

  .suggestion-symbol {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  /* Toggle buttons */
  .toggle-group {
    display: flex;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .toggle-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 9px 16px;
    border: none;
    background: none;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s ease;
  }

  .toggle-btn:not(:last-child) {
    border-right: 1px solid var(--color-border);
  }

  .toggle-btn.active {
    background-color: var(--color-primary-light);
    color: var(--color-primary);
    font-weight: 600;
  }

  .toggle-btn.toggle-short.active {
    background-color: rgba(239, 68, 68, 0.08);
    color: var(--color-accent-red);
  }

  /* Fees */
  .fees-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 0;
    border: none;
    background: none;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
  }

  .fees-toggle:hover { color: var(--color-text); }

  .fees-panel {
    padding-bottom: 4px;
  }

  .fees-row {
    display: flex;
    gap: 12px;
  }

  /* Reset */
  .reset-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s ease;
  }

  .reset-btn:hover {
    border-color: var(--color-accent-red);
    color: var(--color-accent-red);
  }

  /* ===== Results Panel ===== */
  .calc-results-panel {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 28px;
    position: sticky;
    top: 88px;
  }

  .result-hero {
    text-align: center;
    padding: 28px 20px;
    border-radius: var(--radius-md);
    margin-bottom: 24px;
  }

  .result-hero.profit {
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.08), rgba(16, 185, 129, 0.02));
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  .result-hero.loss {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.08), rgba(239, 68, 68, 0.02));
    border: 1px solid rgba(239, 68, 68, 0.2);
  }

  .result-hero-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }

  .result-hero-value {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .result-hero.profit .result-hero-value {
    color: var(--color-accent-green);
  }

  .result-hero.loss .result-hero-value {
    color: var(--color-accent-red);
  }

  .result-hero-roi {
    display: inline-block;
    margin-top: 8px;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .result-hero-roi.profit {
    background-color: rgba(16, 185, 129, 0.1);
    color: var(--color-accent-green);
  }

  .result-hero-roi.loss {
    background-color: rgba(239, 68, 68, 0.1);
    color: var(--color-accent-red);
  }

  /* Breakdown rows */
  .result-breakdown {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.9rem;
  }

  .result-label {
    color: var(--color-text-secondary);
  }

  .result-value {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .result-value.fee {
    color: var(--color-text-muted);
  }

  .result-divider {
    height: 1px;
    background-color: var(--color-border);
    margin: 4px 0;
  }

  /* Disclaimer */
  .calc-disclaimer {
    display: flex;
    align-items: flex-start;
    gap: 6px;
