---
import LocalizedCalculatorPage from '../components/LocalizedCalculatorPage.astro';
import LendingCalculator from '../components/LendingCalculator.tsx';
---

<LocalizedCalculatorPage
  lang="en"
  slug="lending-calculator"
  title="Crypto Lending Calculator"
  description="Calculate projected lending returns using APY, compounding model, term length, and platform performance fees."
>
  <LendingCalculator slot="calculator" lang={typeof lang !== 'undefined' ? lang : 'en'} client:load />
</LocalizedCalculatorPage>

<style>
  .calc-wrapper { width: 100%; }
</style>
