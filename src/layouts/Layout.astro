---
import { SUPPORTED_LANGS, DEFAULT_LANG, getLocalizedPath, getPathWithoutLang, type Lang } from '../i18n/utils';
import CookieBanner from '../components/CookieBanner.astro';

export interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  noindex?: boolean;
  canonical?: string;
  /** Pass 'calculator' on EN calculator pages to auto-generate WebApplication + BreadcrumbList schemas */
  pageType?: 'calculator';
}

const {
  title = 'CryptoCalk — Free Crypto Calculators',
  description = 'Free online cryptocurrency calculators: profit, mining, DCA, tax, staking, and more. Fast, accurate, no signup required.',
  lang = DEFAULT_LANG,
  noindex = false,
  canonical,
  pageType,
} = Astro.props;

const OG_LOCALE_MAP: Record<string, string> = {
  en: 'en_US',
  es: 'es_ES',
  pt: 'pt_BR',
  tr: 'tr_TR',
  hi: 'hi_IN',
  ru: 'ru_RU',
};
const ogLocale = OG_LOCALE_MAP[lang] ?? 'en_US';

const basePath = canonical
  ? getPathWithoutLang(canonical)
  : getPathWithoutLang(Astro.url.pathname);
const canonicalPath = getLocalizedPath(basePath, lang);
const canonicalUrl = `https://cryptocalk.com${canonicalPath}`;

function normalizePath(pathname: string): string {
  const cleaned = pathname.trim();
  if (!cleaned) return '/';
  const withLeadingSlash = cleaned.startsWith('/') ? cleaned : `/${cleaned}`;
  const collapsed = withLeadingSlash.replace(/\/+/g, '/');
  if (collapsed.length > 1 && collapsed.endsWith('/')) {
    return collapsed.slice(0, -1);
  }
  return collapsed;
}

const isCanonicalPath = normalizePath(Astro.url.pathname) === normalizePath(canonicalPath);
const shouldNoindex = noindex || !isCanonicalPath;


// BreadcrumbList for EN calculator pages — 3-level: Home > Category > Calculator.
// Localized pages generate their own schemas in LocalizedCalculatorPage.astro.
// WebApplication schemas live inline in each EN .astro page.
import { CALCULATOR_CATEGORY } from '../data/calculator-category-map';

const CATEGORY_NAMES: Record<string, string> = {
  'profit-loss': 'Profit & Loss',
  'converters': 'Converters',
  'mining': 'Mining',
  'defi-yield': 'DeFi & Yield',
  'tax-reporting': 'Tax & Reporting',
  'investment': 'Investment',
  'trading-tools': 'Trading Tools',
  'gas-fees': 'Gas & Fees',
};

const calcName = title.split(' — ')[0].split(' | ')[0].trim();
const calcSlug = basePath.replace(/^\//, '').replace(/\/$/, '');
const categorySlug = CALCULATOR_CATEGORY[calcSlug] ?? null;
const categoryName = categorySlug ? CATEGORY_NAMES[categorySlug] : null;

const webPageSchema = pageType === 'calculator' ? {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalUrl}#webpage`,
  url: canonicalUrl,
  name: calcName,
  description: description,
  inLanguage: lang,
  isPartOf: { '@type': 'WebSite', '@id': 'https://cryptocalk.com/#website' },
  datePublished: '2025-11-01',
  dateModified: new Date().toISOString().split('T')[0],
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.calc-header h1', '.calc-header p'],
  },
} : null;

const breadcrumbSchema = pageType === 'calculator' ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cryptocalk.com/' },
    ...(categorySlug && categoryName ? [{ '@type': 'ListItem', position: 2, name: categoryName, item: `https://cryptocalk.com/calculators/${categorySlug}/` }] : []),
    { '@type': 'ListItem', position: categorySlug ? 3 : 2, name: calcName, item: canonicalUrl },
  ],
} : null;

// HowTo schema — generic 4-step "use this calculator" instructions for rich-result eligibility on Layout-direct calc pages
const howToSchema = pageType === 'calculator' ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `How to use ${calcName}`,
  description: description,
  totalTime: 'PT1M',
  step: [
    {
      '@type': 'HowToStep',
      name: 'Enter your inputs',
      text: `Enter your values into the ${calcName}'s input fields. Use the quick-scenario presets if you want to load typical assumptions instantly.`,
    },
    {
      '@type': 'HowToStep',
      name: 'Review the live result',
      text: 'Results update in real time as you type — no submit button needed. Compare scenarios by changing any input and watching the result panel adjust.',
    },
    {
      '@type': 'HowToStep',
      name: 'Interpret the breakdown',
      text: 'Use the result breakdown and benchmark zones to gauge whether your scenario sits in a healthy, marginal, or risky range. Cross-reference with the FAQ section below for context.',
    },
    {
      '@type': 'HowToStep',
      name: 'Validate before acting',
      text: 'Before deploying capital, double-check assumptions (price, fees, leverage) against current market data and re-run the calculation with conservative inputs.',
    },
  ],
  inLanguage: lang,
} : null;

// Per-calculator OG image: use /og/{slug}.png for top-10 calculators, else default
const OG_IMAGE_SLUGS = new Set(['profit-calculator','dca-calculator','mining-calculator','tax-calculator','staking-calculator','converter','liquidation-calculator','position-size-calculator','impermanent-loss-calculator','gas-calculator']);
const ogImagePath = OG_IMAGE_SLUGS.has(calcSlug) ? `/og/${calcSlug}.png` : '/og-image.png';

const hreflangRegionMap: Record<string, string> = { en: 'en', es: 'es', pt: 'pt', tr: 'tr', hi: 'hi', ru: 'ru' };

// Slug aliases — map alias slug → canonical slug.
// Localized pages routed via alias slug should hreflang-point to the canonical EN URL,
// not to the alias (which is noindex). Mirrors EN_ALIAS_SLUGS in astro.config.mjs.
const SLUG_ALIASES: Record<string, string> = {
  'gas-fee-calculator': 'gas-calculator',
  'staking-rewards-calculator': 'staking-calculator',
  'compound-interest-calculator': 'compound-calculator',
  'loan-calculator': 'crypto-loan-calculator',
};
function normalizeBasePathForHreflang(p: string): string {
  // p is like '/gas-fee-calculator' or '/staking-rewards-calculator'
  const slug = p.replace(/^\/+|\/+$/g, '').split('/')[0];
  if (slug && SLUG_ALIASES[slug]) {
    return '/' + SLUG_ALIASES[slug];
  }
  return p;
}
const hreflangBasePath = normalizeBasePathForHreflang(basePath);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <!-- Theme init: MUST be first script in <head> to prevent dark-mode FOUC.
         Runs synchronously before any CSS is applied. -->
    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('theme');
          var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch(e) {}
      })();
    </script>
    <meta name="description" content={description} />
    {shouldNoindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Preconnect to Google Fonts + CoinGecko API -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.coingecko.com" crossorigin />
    <!-- Non-blocking font load: preload + onload swap, subset to used weights -->
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700&family=JetBrains+Mono:wght@600;700&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700&family=JetBrains+Mono:wght@600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- PWA manifest -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f172a" />

    <!-- Google tag (gtag.js) -->
    <!-- Consent defaults (set before GA loads — AdSense CMP compliance) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      // Default: deny ad cookies until user accepts via cookie banner
      gtag('consent', 'default', {
        ad_storage: 'denied',
        analytics_storage: 'denied',
        ad_personalization: 'denied',
        ad_user_data: 'denied',
        wait_for_update: 500,
      });
      // Restore saved consent immediately (before banner is painted)
      try {
        var saved = localStorage.getItem('cc_consent');
        if (saved === 'all') {
          gtag('consent', 'update', { ad_storage: 'granted', analytics_storage: 'granted', ad_personalization: 'granted', ad_user_data: 'granted' });
        } else if (saved === 'essential') {
          gtag('consent', 'update', { ad_storage: 'denied', analytics_storage: 'granted', ad_personalization: 'denied', ad_user_data: 'denied' });
        }
      } catch(e) {}
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BVPMVV27NH"></script>
    <script is:inline>
      gtag('js', new Date());
      gtag('config', 'G-BVPMVV27NH');
    </script>

    <!-- Google AdSense — verification + ads loader -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4859241862365215"
      crossorigin="anonymous"></script>
    <meta name="google-adsense-account" content="ca-pub-4859241862365215" />

    <!-- SEO -->
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang tags (language-region codes for better regional SERP targeting) -->
    {SUPPORTED_LANGS.map((l) => (
      <link
        rel="alternate"
        hreflang={hreflangRegionMap[l] ?? l}
        href={`https://cryptocalk.com${getLocalizedPath(hreflangBasePath, l)}`}
      />
    ))}
    <link
      rel="alternate"
      hreflang="x-default"
      href={`https://cryptocalk.com${getLocalizedPath(hreflangBasePath, DEFAULT_LANG)}`}
    />

    <!-- OG Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={`https://cryptocalk.com${ogImagePath}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="CryptoCalk" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@yakovlevka3" />
    <meta name="twitter:creator" content="@yakovlevka3" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://cryptocalk.com${ogImagePath}`} />

    <!-- Schema.org: WebPage + BreadcrumbList for EN calculator pages -->
    {webPageSchema && <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />}
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
    {howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}

    <script>
      import { installCoinGeckoFetchInterceptor } from '../utils/coingecko-fetch-client';

      installCoinGeckoFetchInterceptor();
    </script>

    <!-- Service Worker: offline caching -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function() {
          navigator.serviceWorker.register('/sw.js').catch(function() {});
        });
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">{({es:'Ir al contenido principal',pt:'Ir para o conteúdo principal',tr:'Ana içeriğe geç',hi:'मुख्य सामग्री पर जाएं',ru:'Перейти к основному содержанию'})[lang as string] || 'Skip to main content'}</a>
    <slot />
    <CookieBanner lang={lang} />
    <script is:inline>
      (() => {
        const MOBILE_QUERY = '(max-width: 768px)';
        const _guideLabels = {
          en: ['Read full guide', 'Hide full guide'],
          es: ['Leer guía completa', 'Ocultar guía'],
          pt: ['Ler guia completo', 'Ocultar guia'],
          tr: ['Tam kılavuzu oku', 'Kılavuzu gizle'],
          hi: ['पूरी गाइड पढ़ें', 'गाइड छुपाएं'],
          ru: ['Читать полное руководство', 'Скрыть руководство'],
        };
        const _lang = document.documentElement.lang || 'en';
        const _pair = _guideLabels[_lang] || _guideLabels.en;
        const TOGGLE_SHOW = _pair[0];
        const TOGGLE_HIDE = _pair[1];

        const isMobile = () => window.matchMedia(MOBILE_QUERY).matches;

        const markCalculatorContext = () => {
          const hasCalculator = Boolean(document.querySelector('main .calculator-section'));
          document.body.classList.toggle('calc-mobile-ux', hasCalculator);
        };

        const enhanceSeoSections = () => {
          if (!isMobile()) return;

          document.querySelectorAll('section.seo-content').forEach((section) => {
            if (section.getAttribute('data-mobile-collapsed') === 'true') return;

            const container = section.querySelector('.section-container');
            if (!container || container.children.length < 3) return;

            const collapsible = document.createElement('div');
            collapsible.className = 'seo-mobile-collapsible';

            while (container.firstChild) {
              collapsible.appendChild(container.firstChild);
            }

            const toggle = document.createElement('button');
            toggle.type = 'button';
            toggle.className = 'seo-mobile-toggle';
            toggle.setAttribute('aria-expanded', 'false');
            toggle.textContent = TOGGLE_SHOW;

            const setExpanded = (expanded) => {
              container.setAttribute('data-expanded', expanded ? 'true' : 'false');
              toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
              toggle.textContent = expanded ? TOGGLE_HIDE : TOGGLE_SHOW;
            };

            toggle.addEventListener('click', () => {
              const expanded = container.getAttribute('data-expanded') === 'true';
              setExpanded(!expanded);
            });

            setExpanded(false);
            container.append(toggle, collapsible);
            section.setAttribute('data-mobile-collapsed', 'true');
          });
        };

        const init = () => {
          markCalculatorContext();
          enhanceSeoSections();
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init, { once: true });
        } else {
          init();
        }

        document.addEventListener('astro:after-swap', init);
      })();
    </script>
    <!-- Open external links in system browser (Capacitor app support) -->
    <script is:inline>
      document.addEventListener('click', function(e) {
        var a = e.target.closest('a[href]');
        if (!a) return;
        var href = a.getAttribute('href');
        if (!href || href.startsWith('/') || href.startsWith('#') || href.startsWith('javascript')) return;
        try {
          var url = new URL(href, window.location.origin);
          if (url.hostname === window.location.hostname) return;
          // External link — open in system browser instead of WebView
          e.preventDefault();
          window.open(href, '_blank');
        } catch(err) {}
      }, true);
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
